---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  hasExtraOrb?: boolean;
  hasTransition?: boolean;
  skipTarget?: string;
}

const {
  title = 'Esoterica',
  description,
  bodyClass,
  hasExtraOrb = false,
  hasTransition = false,
  skipTarget = '#main',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#070714" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="stylesheet" href="https://unpkg.com/splitting/dist/splitting.css" />
    <link rel="preload" as="image" href="/logo/logo-160.webp" type="image/webp" />
    <meta name="generator" content={Astro.generator} />

    <!-- GSAP + ScrollTrigger + ScrollToPlugin (same versions as SideStage); SRI sha384 from CDN bytes -->
    <script
      src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"
      integrity="sha384-pEQB1h4Zmn9xhS6jotzltHSIQq6N0Oh3BXkCNOH5LKI81R2NRbb9efarAJYw9gTY"
      crossorigin="anonymous"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/ScrollTrigger.min.js"
      integrity="sha384-TgZ1GoXcDnrw/czNfaiSZSFV1zgIRv8aQOevBA8ppS4SkNONmzYfjARpXsDfdnUE"
      crossorigin="anonymous"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/ScrollToPlugin.min.js"
      integrity="sha384-YY6eh3HcwX3eP3uj3yhZIjt5UBePPmXrYcxT0y0232SA5OGaun9Ivi45Dbm+Z/CQ"
      crossorigin="anonymous"></script>
    <!-- Lenis Smooth Scroll (same version as SideStage) -->
    <script
      src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.23/bundled/lenis.min.js"
      integrity="sha384-GuiQQtSonx5JfFrW04viv7KCVyTAZZKHCXVtcve0DYt8fUPKLdigmPuBh9XBEUD+"
      crossorigin="anonymous"></script>
    <!-- GlslCanvas: vendored locally (previously third-party blob URL) -->
    <script is:inline src="/js/GlslCanvas.js"></script>

    <script is:inline>
      // Disable browser scroll restoration — SideStage pattern
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);
    </script>
    <script is:inline src="https://unpkg.com/splitting/dist/splitting.js"></script>
  </head>
  <body class={`esoterica ${bodyClass ?? ''}`.trim()}>
    <!-- Background starfield: must stay outside .es-site-chrome so it stacks below .page (see #starfield in styles.css) -->
    <canvas id="starfield"></canvas>

    <div class="es-site-chrome">
      <!-- ===== SITE CHROME (hoisted — cursor, orbs, dust, loader above .page) ===== -->
      <a href={skipTarget} class="skip-to-content">Skip to content</a>

      <div class="es-dust" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
      </div>

      {
        hasTransition && (
          <div class="transition">
            <div class="loader-ring"></div>
            <div class="loader-ray"></div>
            <div class="loader-core"></div>
          </div>
        )
      }

      <div class="cursor-rune" aria-hidden="true">
        <div class="cursor-rune-ripple"></div>
        <div class="cursor-rune-ring">
          <div class="cursor-rune-h"></div>
          <div class="cursor-rune-v"></div>
          <div class="cursor-rune-center"></div>
        </div>
      </div>

      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      {hasExtraOrb && <div class="orb orb-3"></div>}

      <slot name="chrome" />
    </div>

    <div class="page">
      <Nav />
      <main id="main">
        <slot />
      </main>
      <Footer />
    </div>

    <slot name="scripts" />

    <!-- ===== SITE CHROME JS (hoisted master rAF + starfield + cursor) ===== -->
    <script is:inline>
      (function () {
        if (window.__ESOTERICA_CHROME_INIT__) return;
        window.__ESOTERICA_CHROME_INIT__ = true;

        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        window.__ESOTERICA_RAF__ = window.__ESOTERICA_RAF__ || {};

        /* STARFIELD — offscreen nebula + frame-skipped twinkle (canonical homepage version) */
        if (!reduce) {
          const canvas = document.getElementById('starfield');
          if (canvas) {
            const ctx = canvas.getContext('2d');
            const STAR_COUNT = 120;
            let stars = [];
            let frameSkip = 0;
            let nebulaCanvas = null;
            let nebulaCtx = null;

            function drawNebula() {
              nebulaCanvas = document.createElement('canvas');
              nebulaCanvas.width = canvas.width;
              nebulaCanvas.height = canvas.height;
              nebulaCtx = nebulaCanvas.getContext('2d');

              const grd = nebulaCtx.createRadialGradient(
                canvas.width * 0.3, canvas.height * 0.4, 0,
                canvas.width * 0.3, canvas.height * 0.4, canvas.width * 0.5
              );
              grd.addColorStop(0, 'rgba(60, 20, 100, 0.03)');
              grd.addColorStop(1, 'transparent');
              nebulaCtx.fillStyle = grd;
              nebulaCtx.fillRect(0, 0, canvas.width, canvas.height);

              const grd2 = nebulaCtx.createRadialGradient(
                canvas.width * 0.7, canvas.height * 0.6, 0,
                canvas.width * 0.7, canvas.height * 0.6, canvas.width * 0.4
              );
              grd2.addColorStop(0, 'rgba(120, 80, 30, 0.02)');
              grd2.addColorStop(1, 'transparent');
              nebulaCtx.fillStyle = grd2;
              nebulaCtx.fillRect(0, 0, canvas.width, canvas.height);
            }

            function createStars() {
              stars = [];
              for (let i = 0; i < STAR_COUNT; i++) {
                stars.push({
                  x: Math.random() * canvas.width,
                  y: Math.random() * canvas.height,
                  r: Math.random() * 1.5 + 0.3,
                  alpha: Math.random(),
                  speed: Math.random() * 0.005 + 0.001,
                  phase: Math.random() * Math.PI * 2
                });
              }
            }

            var comets = [];
            var cometCooldown = 60;
            var attachedComet = null;
            var mouseCanvasX = 0;
            var mouseCanvasY = 0;

            function canvasCoordsFromClient(clientX, clientY) {
              var rect = canvas.getBoundingClientRect();
              return { x: clientX - rect.left, y: clientY - rect.top };
            }

            function pointSegDist(px, py, x1, y1, x2, y2) {
              var dx = x2 - x1;
              var dy = y2 - y1;
              var len2 = dx * dx + dy * dy;
              if (len2 < 1e-8) return Math.hypot(px - x1, py - y1);
              var t = Math.max(0, Math.min(1, ((px - x1) * dx + (py - y1) * dy) / len2));
              var nx = x1 + t * dx;
              var ny = y1 + t * dy;
              return Math.hypot(px - nx, py - ny);
            }

            function hitTestComet(mx, my, c) {
              if (!c.trail || c.trail.length < 1) return false;
              var h = c.trail[0];
              if (Math.hypot(mx - h.x, my - h.y) < 22) return true;
              for (var i = 0; i < c.trail.length - 1; i++) {
                var p1 = c.trail[i];
                var p2 = c.trail[i + 1];
                var taper = i / Math.max(1, c.trail.length);
                var thick = 5 + taper * 10;
                if (pointSegDist(mx, my, p1.x, p1.y, p2.x, p2.y) < thick) return true;
              }
              for (var t = 1; t < c.trail.length; t += 2) {
                var p = c.trail[t];
                var taper = t / c.trail.length;
                var r = 0.6 + taper * 5.5;
                if (Math.hypot(mx - p.x, my - p.y) < r + 8) return true;
              }
              return false;
            }

            function isInteractiveClickTarget(el) {
              if (!el || el === document.body || el === document.documentElement) return false;
              if (el.closest('a[href], button, input, textarea, select, label, summary, [role="button"], [data-scroll]'))
                return true;
              return false;
            }

            function spawnComet() {
              var startX;
              var startY;
              if (Math.random() < 0.6) {
                startX = Math.random() * canvas.width * 0.6;
                startY = -10;
              } else {
                startX = -10;
                startY = Math.random() * canvas.height * 0.5;
              }

              var angle = Math.PI * 0.25 + (Math.random() - 0.5) * 0.4;
              var speed = 7 + Math.random() * 4;
              var trailMax = canvas.width < 768 ? 38 : 70;

              comets.push({
                x: startX,
                y: startY,
                vx: Math.cos(angle) * speed,
                vy: Math.sin(angle) * speed,
                trail: [],
                trailMax: trailMax,
                mist: [],
                age: 0,
                wobblePhase: Math.random() * Math.PI * 2,
                wobbleSpeed: 0.06 + Math.random() * 0.04,
                attached: false
              });
            }

            function emitMistFromTrail(c) {
              if (c.trail.length <= 4) return;
              var srcIdx = 3 + Math.floor(Math.random() * Math.min(8, c.trail.length - 4));
              var src = c.trail[srcIdx];
              if (!src) return;
              var vmag = Math.sqrt(c.vx * c.vx + c.vy * c.vy) || 1;
              var perpX = -c.vy / vmag;
              var perpY = c.vx / vmag;
              var side = Math.random() < 0.5 ? -1 : 1;
              var driftSpeed = 0.25 + Math.random() * 0.45;
              c.mist.push({
                x: src.x + perpX * side * 1.5,
                y: src.y + perpY * side * 1.5,
                vx: perpX * side * driftSpeed,
                vy: perpY * side * driftSpeed,
                alpha: 0.42 + Math.random() * 0.18,
                decay: 0.012 + Math.random() * 0.012,
                size: 0.6 + Math.random() * 0.9,
                grow: 0.06 + Math.random() * 0.05
              });
            }

            function updateComets() {
              var maxComets = canvas.width < 768 ? 1 : 2;
              if (!attachedComet) {
                cometCooldown--;
                if (cometCooldown <= 0 && comets.length < maxComets) {
                  spawnComet();
                  cometCooldown = 160 + Math.floor(Math.random() * 80);
                }
              }

              for (var i = comets.length - 1; i >= 0; i--) {
                var c = comets[i];
                if (c.attached) {
                  var prevX = c.x;
                  var prevY = c.y;
                  c.x += (mouseCanvasX - c.x) * 0.14;
                  c.y += (mouseCanvasY - c.y) * 0.14;
                  var mdx = c.x - prevX;
                  var mdy = c.y - prevY;
                  var ms = Math.sqrt(mdx * mdx + mdy * mdy) || 0;
                  if (ms > 0.02) {
                    c.vx = (mdx / ms) * Math.min(ms * 10, 14);
                    c.vy = (mdy / ms) * Math.min(ms * 10, 14);
                  } else {
                    c.vx *= 0.92;
                    c.vy *= 0.92;
                  }
                  c.age++;
                  c.trail.unshift({ x: c.x, y: c.y, alpha: 1.0 });
                  if (c.trail.length > c.trailMax) c.trail.pop();
                  for (var ta = 0; ta < c.trail.length; ta++) {
                    c.trail[ta].alpha = 1.0 - ta / c.trailMax;
                  }
                  if (ms > 0.12 && c.age % 2 === 0) {
                    emitMistFromTrail(c);
                  }
                  for (var ma = c.mist.length - 1; ma >= 0; ma--) {
                    var mp = c.mist[ma];
                    mp.x += mp.vx;
                    mp.y += mp.vy;
                    mp.size += mp.grow;
                    mp.alpha -= mp.decay;
                    if (mp.alpha <= 0) c.mist.splice(ma, 1);
                  }
                  continue;
                }

                c.x += c.vx;
                c.y += c.vy;
                c.age++;

                c.trail.unshift({ x: c.x, y: c.y, alpha: 1.0 });
                if (c.trail.length > c.trailMax) c.trail.pop();
                for (var t = 0; t < c.trail.length; t++) {
                  c.trail[t].alpha = 1.0 - t / c.trailMax;
                }

                if (c.age % 2 === 0 && c.trail.length > 4) {
                  emitMistFromTrail(c);
                }

                for (var m = c.mist.length - 1; m >= 0; m--) {
                  var mp2 = c.mist[m];
                  mp2.x += mp2.vx;
                  mp2.y += mp2.vy;
                  mp2.size += mp2.grow;
                  mp2.alpha -= mp2.decay;
                  if (mp2.alpha <= 0) c.mist.splice(m, 1);
                }

                if (c.x > canvas.width + 80 || c.y > canvas.height + 80 || c.x < -80 || c.y < -80) {
                  comets.splice(i, 1);
                }
              }
            }

            function drawComets() {
              for (var i = 0; i < comets.length; i++) {
                var c = comets[i];
                if (c.trail.length < 3) continue;

                var wobble = Math.sin(c.age * c.wobbleSpeed + c.wobblePhase) * 0.4;

                var vmag = Math.sqrt(c.vx * c.vx + c.vy * c.vy) || 1;
                var perpX = -c.vy / vmag;
                var perpY = c.vx / vmag;

                for (var t = 1; t < c.trail.length; t += 2) {
                  var p = c.trail[t];
                  var taper = t / c.trail.length;
                  var radius = 0.6 + taper * 5.5;
                  var alpha = p.alpha * 0.07 * (1 - taper * 0.5);
                  ctx.globalAlpha = alpha;
                  ctx.beginPath();
                  ctx.arc(p.x, p.y, radius, 0, Math.PI * 2);
                  ctx.fillStyle = 'rgba(120, 180, 240, 1)';
                  ctx.fill();
                }

                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
                ctx.lineWidth = 1.8;
                for (var t2 = 0; t2 < c.trail.length - 1; t2++) {
                  var p1 = c.trail[t2];
                  var p2 = c.trail[t2 + 1];
                  var taper2 = t2 / c.trail.length;
                  var lineAlpha = p1.alpha * 0.55 * (1 - taper2 * 0.7);
                  var w1 = Math.sin(t2 * 0.3 + c.age * 0.08 + c.wobblePhase) * wobble * (taper2 * 1.5);
                  var w2 = Math.sin((t2 + 1) * 0.3 + c.age * 0.08 + c.wobblePhase) * wobble * ((taper2 + 0.05) * 1.5);
                  ctx.globalAlpha = lineAlpha;
                  ctx.strokeStyle = 'rgba(170, 215, 255, 1)';
                  ctx.beginPath();
                  ctx.moveTo(p1.x + perpX * w1, p1.y + perpY * w1);
                  ctx.lineTo(p2.x + perpX * w2, p2.y + perpY * w2);
                  ctx.stroke();
                }

                ctx.lineWidth = 0.9;
                var coreLen = Math.min(14, c.trail.length - 1);
                for (var t3 = 0; t3 < coreLen; t3++) {
                  var c1 = c.trail[t3];
                  var c2 = c.trail[t3 + 1];
                  var coreAlpha = (1.0 - t3 / coreLen) * 0.85;
                  ctx.globalAlpha = coreAlpha;
                  ctx.strokeStyle = 'rgba(230, 245, 255, 1)';
                  ctx.beginPath();
                  ctx.moveTo(c1.x, c1.y);
                  ctx.lineTo(c2.x, c2.y);
                  ctx.stroke();
                }

                for (var m = 0; m < c.mist.length; m++) {
                  var mp = c.mist[m];
                  ctx.globalAlpha = mp.alpha * 0.25;
                  ctx.beginPath();
                  ctx.arc(mp.x, mp.y, mp.size * 2.2, 0, Math.PI * 2);
                  ctx.fillStyle = 'rgba(190, 220, 250, 1)';
                  ctx.fill();
                  ctx.globalAlpha = mp.alpha * 0.55;
                  ctx.beginPath();
                  ctx.arc(mp.x, mp.y, mp.size, 0, Math.PI * 2);
                  ctx.fillStyle = 'rgba(220, 235, 255, 1)';
                  ctx.fill();
                }

                var head = c.trail[0];
                var headGlow = ctx.createRadialGradient(head.x, head.y, 0, head.x, head.y, 14);
                headGlow.addColorStop(0, 'rgba(240, 250, 255, 0.95)');
                headGlow.addColorStop(0.25, 'rgba(200, 230, 255, 0.55)');
                headGlow.addColorStop(0.55, 'rgba(140, 195, 245, 0.18)');
                headGlow.addColorStop(1, 'rgba(120, 180, 240, 0)');
                ctx.globalAlpha = 1;
                ctx.beginPath();
                ctx.arc(head.x, head.y, 14, 0, Math.PI * 2);
                ctx.fillStyle = headGlow;
                ctx.fill();

                ctx.beginPath();
                ctx.arc(head.x, head.y, 1.6, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(255, 255, 255, 1)';
                ctx.fill();
              }

              ctx.globalAlpha = 1;
            }

            function resize() {
              canvas.width = window.innerWidth;
              canvas.height = window.innerHeight;
              drawNebula();
              createStars();
              comets = [];
              cometCooldown = 60;
              attachedComet = null;
            }

            window.addEventListener('resize', resize);
            resize();

            document.addEventListener(
              'click',
              function (e) {
                if (attachedComet) return;
                var top = document.elementFromPoint(e.clientX, e.clientY);
                if (isInteractiveClickTarget(top)) return;

                var coords = canvasCoordsFromClient(e.clientX, e.clientY);
                if (coords.x < 0 || coords.y < 0 || coords.x > canvas.width || coords.y > canvas.height) return;

                for (var ci = 0; ci < comets.length; ci++) {
                  var com = comets[ci];
                  if (com.attached) continue;
                  if (hitTestComet(coords.x, coords.y, com)) {
                    e.preventDefault();
                    e.stopPropagation();
                    com.attached = true;
                    attachedComet = com;
                    mouseCanvasX = coords.x;
                    mouseCanvasY = coords.y;
                    break;
                  }
                }
              },
              true
            );

            document.addEventListener(
              'mousemove',
              function (e) {
                if (!attachedComet) return;
                var coords = canvasCoordsFromClient(e.clientX, e.clientY);
                mouseCanvasX = coords.x;
                mouseCanvasY = coords.y;
              },
              { passive: true }
            );

            ctx.fillStyle = 'rgb(232, 224, 212)';

            window.__ESOTERICA_RAF__.tickStarfield = function tickStarfield(time) {
              frameSkip = (frameSkip + 1) % 3;
              if (frameSkip !== 0) return;

              ctx.clearRect(0, 0, canvas.width, canvas.height);
              if (nebulaCanvas) ctx.drawImage(nebulaCanvas, 0, 0);

              for (const star of stars) {
                const twinkle = Math.sin(time * star.speed + star.phase) * 0.5 + 0.5;
                const alpha = star.alpha * twinkle * 0.8 + 0.1;
                ctx.globalAlpha = alpha;
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
                ctx.fill();
              }

              updateComets();
              drawComets();

              ctx.globalAlpha = 1;
            };
          }
        }

        let tickCursor = null;
        if (window.matchMedia('(pointer: fine)').matches) {
          const dot = document.querySelector('.cursor-rune');
          if (dot) {
            let mx = 0, my = 0;
            window.addEventListener('mousemove', function (e) {
              mx = e.clientX;
              my = e.clientY;
            }, { passive: true });

            tickCursor = function () {
              dot.style.left = mx + 'px';
              dot.style.top = my + 'px';
            };

            const INTERACTABLES = [
              'a', 'button', '[data-scroll]',
              '.nav-logo', '.nav-link-block',
              '.product-card',
              '.reading-card', '.reading-cta',
              '.class-card', '.class-cta',
              '.es-ct-wa-btn', '.es-ct-wa-number', '.es-ct-channel',
              '.es-lg-contact__link',
              '.es-ft-row', '.es-ft-direct-link'
            ].join(', ');

            document.querySelectorAll(INTERACTABLES).forEach(function (el) {
              el.addEventListener('mouseenter', function () { dot.classList.add('is-hover'); });
              el.addEventListener('mouseleave', function () { dot.classList.remove('is-hover'); });
            });

            window.addEventListener('mousedown', function () { dot.classList.add('is-click'); });
            window.addEventListener('mouseup', function () { dot.classList.remove('is-click'); });
          }
        }

        const tickStarfield = window.__ESOTERICA_RAF__.tickStarfield;

        function esotericaMasterRaf(time) {
          if (typeof tickStarfield === 'function') tickStarfield(time);

          if (window.lenisInstance) {
            window.lenisInstance.raf(time);
            if (window.ScrollTrigger && typeof window.ScrollTrigger.update === 'function') {
              window.ScrollTrigger.update();
            }
          }

          if (typeof tickCursor === 'function') tickCursor();

          requestAnimationFrame(esotericaMasterRaf);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () {
            requestAnimationFrame(esotericaMasterRaf);
          });
        } else {
          requestAnimationFrame(esotericaMasterRaf);
        }
      })();
    </script>
  </body>
</html>
