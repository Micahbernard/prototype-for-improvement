<footer class="es-ft-root">

  <!-- Atmosphere strip -->
  <div class="es-ft-strip">
    <span class="es-ft-strip-text">✦ Chiclayo, Perú</span>
    <span class="es-ft-strip-dot">·</span>
    <span class="es-ft-strip-italic">Where the veil grows thin</span>
    <span class="es-ft-strip-dot">·</span>
    <span class="es-ft-strip-text">Est. 2024 ✦</span>
  </div>

  <!-- Main body -->
  <div class="es-ft-body">

    <!-- Brand bar (full-width centered identity) -->
    <div class="es-ft-brand">
      <div class="es-ft-logo">
        <picture>
          <source type="image/webp" srcset="/logo/logo-48.webp 1x, /logo/logo-96.webp 2x" />
          <img src="/logo/logo-48.png" srcset="/logo/logo-48.png 1x, /logo/logo-96.png 2x" alt="Esoterica" width="44" height="44" loading="lazy" />
        </picture>
        <span class="es-ft-logo-name">Esoterica</span>
      </div>
      <p class="es-ft-desc">Crystals, tarot, and ritual arts.<br/>A threshold, not just a shop.</p>
    </div>

    <!-- Ornamental rule with center glyph -->
    <div class="es-ft-brand-rule" aria-hidden="true"></div>

    <!-- Two row groups (mathematically aligned since they're grid siblings) -->
    <div class="es-ft-cols">

      <nav class="es-ft-group" aria-label="Legal">
        <div class="es-ft-group-head">
          <span class="es-ft-group-label">Legal</span>
          <span class="es-ft-group-count" aria-hidden="true">/ III</span>
        </div>
        <a href="/privacy" class="es-ft-row es-ft-row--legal">
          <span class="es-ft-row-num">I</span>
          <span class="es-ft-row-label">Privacy Policy</span>
          <span class="es-ft-row-arrow">↗</span>
        </a>
        <a href="/terms" class="es-ft-row es-ft-row--legal">
          <span class="es-ft-row-num">II</span>
          <span class="es-ft-row-label">Terms of Use</span>
          <span class="es-ft-row-arrow">↗</span>
        </a>
        <a href="/contact" class="es-ft-row es-ft-row--legal">
          <span class="es-ft-row-num">III</span>
          <span class="es-ft-row-label">Contact</span>
          <span class="es-ft-row-arrow">↗</span>
        </a>
      </nav>

      <nav class="es-ft-group" aria-label="Social">
        <div class="es-ft-group-head">
          <span class="es-ft-group-label">Find Us</span>
          <span class="es-ft-group-count" aria-hidden="true">/ III</span>
        </div>
        <a href="https://www.instagram.com/esoterica.cix/" target="_blank" rel="noopener" class="es-ft-row">
          <span class="es-ft-row-num">I</span>
          <span class="es-ft-row-label">Instagram</span>
          <span class="es-ft-row-arrow">↗</span>
        </a>
        <a href="https://www.tiktok.com/@esoterica.cix" target="_blank" rel="noopener" class="es-ft-row">
          <span class="es-ft-row-num">II</span>
          <span class="es-ft-row-label">TikTok</span>
          <span class="es-ft-row-arrow">↗</span>
        </a>
        <a href="https://pinterest.com/esoterica" target="_blank" rel="noopener" class="es-ft-row">
          <span class="es-ft-row-num">III</span>
          <span class="es-ft-row-label">Pinterest</span>
          <span class="es-ft-row-arrow">↗</span>
        </a>
      </nav>

    </div>

    <!-- Direct line: email pulled out of social rows, elevated -->
    <div class="es-ft-direct">
      <span class="es-ft-direct-label">Direct Line</span>
      <a href="mailto:commune@esoterica.com" class="es-ft-direct-link">
        <span class="es-ft-direct-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="M3 7l9 6 9-6"></path>
          </svg>
        </span>
        commune@esoterica.com
      </a>
    </div>

    <!-- Close: copyright anchor -->
    <div class="es-ft-close">
      <p class="es-ft-close-text">© 2026 Esoterica · All rights reserved</p>
    </div>

  </div>

  <!-- Full-width wordmark: interactive constellation canvas only -->
  <div class="es-ft-wordmark-wrap">
    <canvas class="es-ft-constellation" aria-hidden="true"></canvas>
  </div>

</footer>

<script is:inline>
(function() {
  if (!window.matchMedia('(pointer: fine)').matches) return;
  if (!window.gsap) return;
  document.querySelectorAll('.es-ft-row').forEach(function(row) {
    var label = row.querySelector('.es-ft-row-label');
    row.addEventListener('mousemove', function(e) {
      var rect = row.getBoundingClientRect();
      var x = ((e.clientX - rect.left) / rect.width - 0.5) * 10;
      gsap.to(label, { x: x, duration: 0.4, ease: 'power2.out' });
    });
    row.addEventListener('mouseleave', function() {
      gsap.to(label, { x: 0, duration: 0.5, ease: 'power2.out' });
    });
  });
})();
</script>

<script is:inline>
(function() {
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var goldR = 212;
  var goldG = 168;
  var goldB = 83;
  var textR = 232;
  var textG = 224;
  var textB = 212;

  var canvas;
  var ctx;
  var W;
  var H;
  var dpr;
  var stars;
  var lines;
  var time;
  var lineAlpha;
  var starBaseAlpha;
  var revealed;
  var animating;
  var rafId;
  var stopRaf;
  var footerVisible;
  var observer;
  var resizeTimer;
  var wrap;
  var wrapClickHandler;
  var reduceClickHandler;
  var textFillAlpha = 0;
  var textFillTweenObj = { a: 0 };

  function cancelLoop() {
    if (rafId) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }
  }

  function teardown() {
    cancelLoop();
    if (typeof gsap !== 'undefined') {
      gsap.killTweensOf(textFillTweenObj);
      if (stars && stars.length) {
        stars.forEach(function(s) {
          gsap.killTweensOf(s);
        });
      }
    }
    if (wrap && wrapClickHandler) {
      wrap.removeEventListener('click', wrapClickHandler);
      wrapClickHandler = null;
    }
    if (wrap && reduceClickHandler) {
      wrap.removeEventListener('click', reduceClickHandler);
      reduceClickHandler = null;
    }
    if (observer) {
      observer.disconnect();
      observer = null;
    }
  }

  function init() {
    teardown();

    canvas = document.querySelector('.es-ft-constellation');
    wrap = document.querySelector('.es-ft-wordmark-wrap');
    if (!canvas || !wrap) return;

    ctx = canvas.getContext('2d');
    revealed = false;
    animating = false;
    stopRaf = false;
    time = 0;
    lineAlpha = 0.08;
    starBaseAlpha = 0.55;
    textFillAlpha = 0;
    textFillTweenObj.a = 0;

    dpr = Math.min(window.devicePixelRatio || 1, 2);
    var rect = canvas.getBoundingClientRect();
    W = rect.width;
    H = rect.height;
    if (W < 8 || H < 8) return;

    canvas.width = W * dpr;
    canvas.height = H * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);

    var offscreen = document.createElement('canvas');
    offscreen.width = W * dpr;
    offscreen.height = H * dpr;
    var offCtx = offscreen.getContext('2d');
    offCtx.setTransform(1, 0, 0, 1, 0, 0);
    offCtx.scale(dpr, dpr);

    var fontSize = Math.min(W * 0.13, H * 0.7);
    offCtx.font = '600 ' + fontSize + 'px Cinzel, serif';
    offCtx.textAlign = 'center';
    offCtx.textBaseline = 'middle';
    offCtx.fillStyle = '#fff';
    offCtx.fillText('ESOTERICA', W / 2, H / 2);

    var imageData = offCtx.getImageData(0, 0, offscreen.width, offscreen.height);
    var pixels = imageData.data;
    var truePoints = [];
    var sampleStep = Math.max(4, Math.floor(fontSize / 8));
    var stepPx = Math.max(1, Math.floor(sampleStep * dpr));

    for (var py = 0; py < offscreen.height; py += stepPx) {
      for (var px = 0; px < offscreen.width; px += stepPx) {
        var idx = (py * offscreen.width + px) * 4;
        if (pixels[idx + 3] > 128) {
          truePoints.push({ x: px / dpr, y: py / dpr });
        }
      }
    }

    var targetCount =
      W < 768
        ? Math.min(Math.max(60, Math.floor(W / 8)), 100)
        : Math.min(Math.max(100, Math.floor(W / 6)), 180);
    while (truePoints.length > targetCount) {
      truePoints.splice(Math.floor(Math.random() * truePoints.length), 1);
    }

    if (!truePoints.length) {
      return;
    }

    stars = truePoints.map(function(p) {
      var angle = Math.random() * Math.PI * 2;
      var scatter = 30 + Math.random() * 40;

      return {
        trueX: p.x,
        trueY: p.y,
        scatterX: p.x + Math.cos(angle) * scatter,
        scatterY: p.y + Math.sin(angle) * scatter,
        currentX: 0,
        currentY: 0,
        size: 1.0 + Math.random() * 1.5,
        twinkleSpeed: 0.01 + Math.random() * 0.02,
        twinklePhase: Math.random() * Math.PI * 2,
        brightness: 0.5 + Math.random() * 0.5
      };
    });

    for (var i = 0; i < stars.length; i++) {
      stars[i].currentX = stars[i].scatterX;
      stars[i].currentY = stars[i].scatterY;
    }

    /* Lines = letter outline only: connect stars whose TRUE positions are neighbors on the
       text sample grid (not scatter distance — avoids dense web). Revealed state traces ESOTERICA. */
    lines = [];
    var stepCss = stepPx / dpr;
    var adjThreshold = stepCss * 1.9;
    for (var li = 0; li < stars.length; li++) {
      for (var lj = li + 1; lj < stars.length; lj++) {
        var tdx = stars[li].trueX - stars[lj].trueX;
        var tdy = stars[li].trueY - stars[lj].trueY;
        var td = Math.sqrt(tdx * tdx + tdy * tdy);
        if (td <= adjThreshold && td > 0.15) {
          lines.push({ a: li, b: lj, dist: td });
        }
      }
    }
    lines.sort(function(a, b) {
      return a.dist - b.dist;
    });
    var maxOutlineEdges = Math.floor(stars.length * 2.2);
    if (lines.length > maxOutlineEdges) {
      lines = lines.slice(0, maxOutlineEdges);
    }

    function draw() {
      if (stopRaf) {
        cancelLoop();
        return;
      }
      time++;
      ctx.clearRect(0, 0, W, H);

      /* Readable typography: filled + stroked ESOTERICA (same geometry as the star sample) */
      if (textFillAlpha > 0.001) {
        ctx.save();
        ctx.globalAlpha = textFillAlpha;
        ctx.font = '600 ' + fontSize + 'px Cinzel, serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillStyle = 'rgba(' + textR + ',' + textG + ',' + textB + ', 1)';
        ctx.fillText('ESOTERICA', W / 2, H / 2);
        ctx.lineJoin = 'round';
        ctx.lineCap = 'round';
        ctx.strokeStyle = 'rgba(' + goldR + ',' + goldG + ',' + goldB + ', 0.42)';
        ctx.lineWidth = 1.35;
        ctx.strokeText('ESOTERICA', W / 2, H / 2);
        ctx.restore();
      }

      /* Constellation lines only in idle state — hide during/after reveal so real text reads clearly */
      var showLines = lines.length && !animating && !revealed;
      if (showLines) {
        var lineVis = lineAlpha * 0.18;
        var lineW = 0.45;
        for (var li = 0; li < lines.length; li++) {
          var a = stars[lines[li].a];
          var b = stars[lines[li].b];
          ctx.globalAlpha = lineVis;
          ctx.strokeStyle = 'rgba(' + goldR + ',' + goldG + ',' + goldB + ', 1)';
          ctx.lineWidth = lineW;
          ctx.beginPath();
          ctx.moveTo(a.currentX, a.currentY);
          ctx.lineTo(b.currentX, b.currentY);
          ctx.stroke();
        }
      }

      var starDim = 1 - textFillAlpha * 0.45;
      if (starDim < 0.38) starDim = 0.38;

      for (var si = 0; si < stars.length; si++) {
        var s = stars[si];
        var twinkle = Math.sin(time * s.twinkleSpeed + s.twinklePhase) * 0.3 + 0.7;
        var alpha = starBaseAlpha * s.brightness * twinkle * starDim;

        ctx.globalAlpha = alpha * 0.3;
        ctx.beginPath();
        ctx.arc(s.currentX, s.currentY, s.size * 3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + goldR + ',' + goldG + ',' + goldB + ', 1)';
        ctx.fill();

        ctx.globalAlpha = alpha;
        ctx.beginPath();
        ctx.arc(s.currentX, s.currentY, s.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + textR + ',' + textG + ',' + textB + ', 1)';
        ctx.fill();
      }

      ctx.globalAlpha = 1;

      if (footerVisible && !stopRaf) {
        rafId = requestAnimationFrame(draw);
      }
    }

    function startLoopIfNeeded() {
      if (reduce || stopRaf) return;
      if (!footerVisible) return;
      if (!rafId) {
        rafId = requestAnimationFrame(draw);
      }
    }

    observer = new IntersectionObserver(
      function(entries) {
        footerVisible = entries[0] && entries[0].isIntersecting;
        if (footerVisible) {
          startLoopIfNeeded();
        } else {
          cancelLoop();
        }
      },
      { rootMargin: '100px' }
    );
    observer.observe(canvas);

    var cr0 = canvas.getBoundingClientRect();
    footerVisible = cr0.bottom > -100 && cr0.top < window.innerHeight + 100;

    if (reduce) {
      time = 0;
      draw();
      cancelLoop();

      reduceClickHandler = function() {
        if (revealed) return;
        revealed = true;
        for (var ri = 0; ri < stars.length; ri++) {
          stars[ri].currentX = stars[ri].trueX;
          stars[ri].currentY = stars[ri].trueY;
        }
        lineAlpha = 0.25;
        starBaseAlpha = 0.95;
        textFillAlpha = 1;
        textFillTweenObj.a = 1;
        draw();
        cancelLoop();
      };
      wrap.addEventListener('click', reduceClickHandler);
      return;
    }

    wrapClickHandler = function() {
      if (revealed || animating) return;
      if (typeof gsap === 'undefined') return;
      animating = true;

      stars.forEach(function(s, idx) {
        gsap.to(s, {
          currentX: s.trueX,
          currentY: s.trueY,
          duration: 1.2 + Math.random() * 0.6,
          ease: 'power3.inOut',
          delay: idx * 0.008
        });
      });

      var lineTween = { v: lineAlpha };
      gsap.to(lineTween, {
        v: 0.25,
        duration: 1.5,
        ease: 'power2.out',
        onUpdate: function() {
          lineAlpha = lineTween.v;
        }
      });

      var starTween = { v: starBaseAlpha };
      gsap.to(starTween, {
        v: 0.95,
        duration: 1.5,
        ease: 'power2.out',
        onUpdate: function() {
          starBaseAlpha = starTween.v;
        }
      });

      textFillTweenObj.a = 0;
      textFillAlpha = 0;
      gsap.to(textFillTweenObj, {
        a: 1,
        duration: 1,
        delay: 1.35,
        ease: 'power2.out',
        onUpdate: function() {
          textFillAlpha = textFillTweenObj.a;
        }
      });

      gsap.delayedCall(1.8, function() {
        animating = false;
        revealed = true;
      });

      gsap.delayedCall(4.8, function() {
        stopRaf = true;
        cancelLoop();
      });
    };
    wrap.addEventListener('click', wrapClickHandler);

    startLoopIfNeeded();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(init, 300);
  });
})();
</script>
