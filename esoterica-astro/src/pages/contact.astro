  <script is:inline slot="scripts">
/* ===== STARFIELD ===== */
        (function () {
            const canvas = document.getElementById('starfield');
            const ctx = canvas.getContext('2d');
            let stars = [];
            const STAR_COUNT = 120;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }

            function init() {
                stars = Array.from({ length: STAR_COUNT }, () => ({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: Math.random() * 1.2 + 0.3,
                    alpha: Math.random() * 0.6 + 0.1,
                    speed: Math.random() * 0.008 + 0.004,
                    phase: Math.random() * Math.PI * 2,
                }));
            }

            function draw(t) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                stars.forEach(s => {
                    const a = s.alpha * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(232,224,212,${a})`;
                    ctx.fill();
                });
                requestAnimationFrame(draw);
            }

            resize();
            init();
            window.addEventListener('resize', () => { resize(); init(); });
            requestAnimationFrame(draw);
        })();

        /* ===== CUSTOM CURSOR ===== */
        (function () {
            const dot = document.querySelector('.cursor-rune');
            if (!dot) return;
            document.addEventListener('mousemove', e => {
                dot.style.left = e.clientX + 'px';
                dot.style.top = e.clientY + 'px';
            });
            const interactables = 'a, button, .es-ct-wa-btn, .es-ct-channel, .es-ct-wa-number, .nav-link-block';
            document.querySelectorAll(interactables).forEach(el => {
                el.addEventListener('mouseenter', () => dot.classList.add('is-hover'));
                el.addEventListener('mouseleave', () => dot.classList.remove('is-hover'));
            });
            window.addEventListener('mousedown', () => dot.classList.add('is-click'));
            window.addEventListener('mouseup', () => dot.classList.remove('is-click'));
        })();

        /* ===== GSAP ANIMATIONS ===== */
        (function () {
            if (typeof gsap === 'undefined') return;

            gsap.registerPlugin(ScrollTrigger);

            gsap.from('.page-hero .hero-breadcrumb', { opacity: 0, y: 10, duration: 0.8, ease: 'power3.out', delay: 0.3 });
            gsap.from('.page-hero .hero-title', { opacity: 0, y: 20, duration: 1, ease: 'power3.out', delay: 0.5 });
            gsap.from('.page-hero .hero-subtitle', { opacity: 0, y: 15, duration: 0.8, ease: 'power3.out', delay: 0.7 });

            gsap.from('.es-ct-primary', { opacity: 0, y: 40, duration: 1, ease: 'power3.out', delay: 0.3 });
            gsap.from('.es-ct-secondary', { opacity: 0, x: 30, duration: 1, ease: 'power3.out', delay: 0.5 });

            // Sub-hero parallax depth
            if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
                const subHero = document.querySelector(".sub-hero-cosmos");
                const subHeroInner = document.querySelector(".sub-hero-cosmos-inner");
                const subHeroSigil = document.querySelector(".hero-sigil");

                if (subHero && subHeroInner) {
                    // Layer 1 — background glow (slowest, 15% scroll rate)
                    gsap.to(subHero, {
                        backgroundPositionY: "30%",
                        ease: "none",
                        scrollTrigger: {
                            trigger: subHero,
                            start: "top top",
                            end: "bottom top",
                            scrub: true
                        }
                    });

                    // Layer 2 — sigil logo (medium, 25% scroll rate)
                    if (subHeroSigil) {
                        gsap.to(subHeroSigil, {
                            y: -40,
                            ease: "none",
                            scrollTrigger: {
                                trigger: subHero,
                                start: "top top",
                                end: "bottom top",
                                scrub: true
                            }
                        });
                    }

                    // Layer 3 — text content (fastest, 45% scroll rate)
                    gsap.to(subHeroInner, {
                        y: -70,
                        opacity: 0,
                        ease: "none",
                        scrollTrigger: {
                            trigger: subHero,
                            start: "top top",
                            end: "60% top",
                            scrub: true
                        }
                    });
                }
            }
        })();
  </script>
</Layout>
