---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
/* ===== HERO (outer shell; inner .sub-hero-cosmos in styles.css) ===== */
        /* inner-page override */
        .page-hero {
            padding: 5.5rem 1.25rem 2.5rem;
            position: relative;
        }

        /* inner-page override */
        .hero-sigil {
            margin-bottom: 1.5rem;
        }

        /* inner-page override */
        .hero-sigil img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            object-position: center 58%;
            border-radius: 50%;
            filter: drop-shadow(0 0 16px rgba(212, 168, 83, 0.3)) drop-shadow(0 0 40px rgba(90, 50, 140, 0.15));
        }

        /* inner-page override */
        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 500;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            max-width: 700px;
        }

        /* inner-page override */
        .hero-subtitle {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.05rem, 1.8vw, 1.3rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            max-width: var(--es-max-prose);
            margin: 0 auto;
        }

        body.pg-contact .sub-hero-cosmos {
            min-height: min(55vh, 480px);
            border-color: rgba(37, 211, 102, 0.12);
            box-shadow: inset 0 0 80px rgba(37, 211, 102, 0.04);
        }
        body.pg-contact .sub-hero-cosmos::before {
            background:
                radial-gradient(ellipse 40% 35% at 68% 68%, rgba(37, 211, 102, 0.09) 0%, transparent 60%),
                radial-gradient(ellipse 70% 55% at 50% 55%, rgba(20, 100, 50, 0.05) 0%, transparent 72%);
        }
        body.pg-contact .hero-sigil {
            display: none;
        }
        body.pg-contact .hero-title {
            font-size: clamp(2.8rem, 6vw, 4.5rem);
            margin-bottom: 1.5rem;
        }
</style>

<Layout title="Contact — Esoterica" description="Reach Esoterica directly — WhatsApp, email, and social." bodyClass="pg-contact">
