  <div class="cursor-rune" aria-hidden="true">
    <div class="cursor-rune-ripple"></div>
    <div class="cursor-rune-ring">
      <div class="cursor-rune-h"></div>
      <div class="cursor-rune-v"></div>
      <div class="cursor-rune-center"></div>
    </div>
  </div>
  <canvas id="starfield"></canvas>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  </div>

<section class="page-hero">
  <div class="sub-hero-cosmos">
    <div class="sub-hero-cosmos-inner">
      <div class="hero-breadcrumb">
        <a href="/">Home</a> &nbsp;/&nbsp; Contact
      </div>
      <h1 class="hero-title">Speak Into the Veil</h1>
      <p class="hero-subtitle">
        We read every message. Reach us directly — no forms, no waiting rooms.<br/>
        Just a conversation, held with intention.
      </p>
    </div>
  </div>
</section>

