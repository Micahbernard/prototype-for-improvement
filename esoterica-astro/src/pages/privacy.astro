---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
/* ===== HERO (outer shell; inner .sub-hero-cosmos in styles.css) ===== */
        /* inner-page override */
        .page-hero {
            padding: 5.5rem 1.25rem 2.5rem;
            position: relative;
        }

        /* inner-page override */
        .hero-sigil {
            margin-bottom: 1.5rem;
        }

        /* inner-page override */
        .hero-sigil img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            object-position: center 58%;
            border-radius: 50%;
            filter: drop-shadow(0 0 16px rgba(212, 168, 83, 0.3)) drop-shadow(0 0 40px rgba(90, 50, 140, 0.15));
        }

        /* inner-page override */
        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 500;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            max-width: 700px;
        }

        /* inner-page override */
        .hero-subtitle {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.05rem, 1.8vw, 1.3rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            max-width: var(--es-max-prose);
            margin: 0 auto;
        }

        /* ===== SECTION SHARED ===== */
        /* inner-page override */
        .section {
            padding: 6rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        /* inner-page override */
        .section-divider {
            width: 60px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--es-gold), transparent);
            margin: 0 auto 2rem;
        }

        /* inner-page override */
        .section-label {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 1rem;
        }

        /* inner-page override */
        .section-heading {
            font-family: 'Cinzel', serif;
            font-size: clamp(1.8rem, 3.5vw, 2.8rem);
            font-weight: 500;
            text-align: center;
            margin-bottom: 1.5rem;
        }

        /* inner-page override */
        .section-description {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            text-align: center;
            max-width: var(--es-max-prose);
            margin: 0 auto 3rem;
        }

        /* ===== CLASS CARDS GRID ===== */
        .classes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .class-card {
            background: var(--es-bg-card-soft);
            border: 1px solid var(--es-border-card);
            border-radius: var(--es-radius-card-sm);
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
            cursor: pointer;
        }

        .class-card:hover {
            transform: translateY(-6px);
            border-color: var(--es-border-card-hover);
            box-shadow: var(--es-shadow-card-hover);
        }

        .class-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 20%, rgba(100, 60, 180, 0.08) 0%, transparent 60%);
            pointer-events: none;
        }

        .class-icon {
            font-size: 2.5rem;
            margin-bottom: 1.2rem;
            display: block;
            color: var(--es-gold);
        }

        .class-icon svg {
            display: block;
            margin: 0 auto;
        }

        .class-badge {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            margin-bottom: 1rem;
        }

        .class-name {
            font-family: 'Cinzel', serif;
            font-size: 1.3rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .class-type {
            font-family: 'Inter', sans-serif;
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-gold);
            margin-bottom: 1rem;
        }

        .class-desc {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: rgba(var(--es-text-rgb), 0.68);
            margin-bottom: 1.5rem;
        }

        .class-details {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            color: var(--es-text-faint);
            margin-bottom: 1.5rem;
            line-height: 1.8;
        }

        .class-price {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--es-gold);
            margin-bottom: 1.5rem;
        }

        .class-cta {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
        }

        .class-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(212, 168, 83, 0.25);
        }

        /* ===== FORMAT SECTION ===== */
        .format-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2.5rem;
            text-align: center;
        }

        .format-item {
            position: relative;
        }

        .format-icon {
            font-size: 2rem;
            color: rgba(var(--es-gold-rgb), 0.6);
            margin-bottom: 1rem;
        }

        .format-title {
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            font-weight: 500;
            margin-bottom: 0.6rem;
        }

        .format-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.95rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: var(--es-text-faint);
        }

        /* ===== QUOTE ===== */
        /* inner-page override */
        .quote-section {
            text-align: center;
            padding: 5rem 2rem;
        }

        /* inner-page override */
        .quote-mark {
            font-family: 'Cinzel', serif;
            font-size: 5rem;
            line-height: 1;
            color: rgba(var(--es-gold-rgb), 0.15);
        }

        /* inner-page override */
        .quote-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.2rem, 2.5vw, 1.6rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-subtle);
            max-width: 600px;
            margin: 0 auto 1rem;
        }

        /* inner-page override */
        .quote-author {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-text-dim);
        }
</style>

<Layout title="Privacy Policy — Esoterica" description="Privacy Policy — Esoterica.">
  <div slot="chrome">
  <div class="cursor-dot"></div>
  <canvas id="starfield"></canvas>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  </div>

<!-- ===== HERO ===== -->
        <section class="page-hero">
            <div class="sub-hero-cosmos">
                <div class="sub-hero-cosmos-inner">
                    <div class="hero-sigil">
                        <img src="/logo.png" alt="Esoterica" width="100" height="100" />
                    </div>
                    <div class="hero-breadcrumb">
                        <a href="/">Home</a> &nbsp;/&nbsp; Privacy
                    </div>
                    <h1 class="hero-title">Privacy Policy</h1>
                    <p class="hero-subtitle">
                        This page is a placeholder. A full privacy policy will appear here.
                    </p>
                </div>
            </div>
        </section>
  <script is:inline slot="scripts">
/* ===== STARFIELD ===== */
        (function () {
            const canvas = document.getElementById('starfield');
            const ctx = canvas.getContext('2d');
            let stars = [];
            const STAR_COUNT = 120;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }

            function init() {
                stars = Array.from({ length: STAR_COUNT }, () => ({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: Math.random() * 1.2 + 0.3,
                    alpha: Math.random() * 0.6 + 0.1,
                    speed: Math.random() * 0.008 + 0.004,
                    phase: Math.random() * Math.PI * 2,
                }));
            }

            function draw(t) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                stars.forEach(s => {
                    const a = s.alpha * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(232,224,212,${a})`;
                    ctx.fill();
                });
                requestAnimationFrame(draw);
            }

            resize();
            init();
            window.addEventListener('resize', () => { resize(); init(); });
            requestAnimationFrame(draw);
        })();

        /* ===== CUSTOM CURSOR ===== */
        (function () {
            const dot = document.querySelector('.cursor-dot');
            if (!dot) return;
            document.addEventListener('mousemove', e => {
                dot.style.left = e.clientX + 'px';
                dot.style.top = e.clientY + 'px';
            });
            const interactables = 'a, button, .class-card, .class-cta, .nav-link-block';
            document.querySelectorAll(interactables).forEach(el => {
                el.addEventListener('mouseenter', () => dot.classList.add('is-hover'));
                el.addEventListener('mouseleave', () => dot.classList.remove('is-hover'));
            });
        })();

        /* ===== GSAP ANIMATIONS ===== */
        (function () {
            if (typeof gsap === 'undefined') return;

            gsap.registerPlugin(ScrollTrigger);

            gsap.from('.page-hero .hero-sigil', { opacity: 0, y: -20, duration: 1, ease: 'power3.out', delay: 0.3 });
            gsap.from('.page-hero .hero-breadcrumb', { opacity: 0, y: 10, duration: 0.8, ease: 'power3.out', delay: 0.5 });
            gsap.from('.page-hero .hero-title', { opacity: 0, y: 20, duration: 1, ease: 'power3.out', delay: 0.7 });
            gsap.from('.page-hero .hero-subtitle', { opacity: 0, y: 15, duration: 0.8, ease: 'power3.out', delay: 0.9 });

            document.querySelectorAll('.class-card').forEach((card, i) => {
                gsap.from(card, {
                    scrollTrigger: { trigger: card, start: 'top 85%' },
                    opacity: 0, y: 30, duration: 0.7, ease: 'power3.out', delay: i * 0.08
                });
            });

            document.querySelectorAll('.format-item').forEach((item, i) => {
                gsap.from(item, {
                    scrollTrigger: { trigger: item, start: 'top 88%' },
                    opacity: 0, y: 20, duration: 0.6, ease: 'power2.out', delay: i * 0.1
                });
            });
        })();
  </script>
</Layout>
