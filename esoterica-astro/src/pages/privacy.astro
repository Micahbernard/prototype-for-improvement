---
import Layout from '../layouts/Layout.astro';

const lastUpdated = 'April 2026';

const sections = [
  { id: 'who-we-are', label: 'Who we are' },
  { id: 'what-we-collect', label: 'What we collect' },
  { id: 'how-we-use', label: 'How we use information' },
  { id: 'cookies', label: 'Cookies & similar tech' },
  { id: 'third-parties', label: 'Third parties' },
  { id: 'your-rights', label: 'Your rights (ARCO+)' },
  { id: 'retention', label: 'How long we keep data' },
  { id: 'security', label: 'Security' },
  { id: 'minors', label: 'Minors' },
  { id: 'changes', label: 'Changes to this policy' },
] as const;
---

<Layout
  title="Privacy Policy — Esoterica"
  description="Privacy Policy for Esoterica, Chiclayo, Perú — how we process personal data under Ley N° 29733 (Ley de Protección de Datos Personales) and your ARCO rights."
  bodyClass="pg-privacy"
>

  <section class="es-lg-hero" aria-labelledby="privacy-title">
    <div class="es-lg-hero__inner">
      <nav class="es-lg-crumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li aria-current="page">Privacy Policy</li>
        </ol>
      </nav>
      <div class="es-lg-rule" aria-hidden="true"></div>
      <h1 id="privacy-title" class="es-lg-title">Privacy Policy</h1>
      <p class="es-lg-lede">
        How Esoterica collects, uses, and protects personal information when you visit our site, message us, book a reading, or shop with us — in line with Peruvian law.
      </p>
      <p class="es-lg-meta">Last updated · {lastUpdated}</p>
    </div>
  </section>

  <article class="es-lg-body">
    <nav class="es-lg-toc" aria-labelledby="toc-heading">
      <h2 id="toc-heading" class="es-lg-toc__label">On this page</h2>
      <ol>
        {sections.map((s) => (
          <li>
            <a href={`#${s.id}`}>{s.label}</a>
          </li>
        ))}
      </ol>
    </nav>

    <section class="es-lg-section" id="who-we-are" aria-labelledby="h-who">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-who" class="es-lg-h2">Who we are</h2>
      <p class="es-lg-p">
        <strong>Esoterica</strong> is a small esoteric shop based in <em>Chiclayo, Lambayeque, Perú</em>. We sell crystals, tarot decks, ritual goods, and related services including readings and workshops. When this policy says “we,” “us,” or “our,” it refers to Esoterica as the data controller for the processing described here.
      </p>
      <p class="es-lg-p">
        We process personal data in accordance with <strong>Ley N° 29733</strong>, Ley de Protección de Datos Personales, its regulations, and other applicable Peruvian norms. This policy explains what we collect, why we use it, who we share it with, how long we keep it, and the rights you have — including <em>acceso, rectificación, cancelación, oposición</em> and related protections.
      </p>
      <p class="es-lg-note">
        This policy is provided in good faith for transparency. It is not legal advice. We recommend that a qualified attorney in Perú review it before you rely on it for compliance or publication.
      </p>
    </section>

    <section class="es-lg-section" id="what-we-collect" aria-labelledby="h-collect">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-collect" class="es-lg-h2">What we collect</h2>
      <p class="es-lg-p">
        <strong>Information you give us.</strong> When you contact us (for example via WhatsApp or email), place an order, book a reading or class, or sign up for updates, you may provide your name, phone number, email address, delivery address, payment references (for bank transfer, Yape, Plin, or similar), and the content of your messages. If you attend a reading, you might share personal topics voluntarily; we treat that information with care and do not use it for unrelated marketing.
      </p>
      <p class="es-lg-p">
        <strong>Information collected automatically.</strong> Like most sites, our hosting and infrastructure may process technical data such as browser type, device type, approximate region (from IP at aggregate level), and pages visited. We use this to keep the site secure, fix errors, and understand traffic in aggregate — not to build invasive profiles.
      </p>
      <p class="es-lg-p">
        We do not ask for special categories of sensitive data (such as health data) as a condition of using the shop. If you voluntarily share sensitive information during a spiritual consultation, we only use it to provide that service unless you consent otherwise or the law requires otherwise.
      </p>
    </section>

    <section class="es-lg-section" id="how-we-use" aria-labelledby="h-use">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-use" class="es-lg-h2">How we use information</h2>
      <p class="es-lg-p">We use personal data to:</p>
      <ul class="es-lg-list">
        <li>Respond to inquiries and provide customer support</li>
        <li>Process and deliver orders, and coordinate shipping within Perú (and internationally only when agreed)</li>
        <li>Schedule and deliver readings, classes, and events you book</li>
        <li>Meet accounting, tax, and legal obligations under Peruvian law</li>
        <li>Improve our website and services in a privacy-respecting way</li>
        <li>Protect against fraud, abuse, or security incidents</li>
      </ul>
      <p class="es-lg-p">
        We do <strong>not</strong> sell your personal data. We do not use it for automated decision-making that affects your legal rights. We do not build cross-site tracking profiles for advertising brokers.
      </p>
    </section>

    <section class="es-lg-section" id="cookies" aria-labelledby="h-cookies">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-cookies" class="es-lg-h2">Cookies &amp; similar technologies</h2>
      <p class="es-lg-p">
        We may use strictly necessary cookies or local storage required for the site to function (for example session stability or security). If we use privacy-respecting analytics, it will be configured to minimize identification and retention. You can block cookies in your browser; some features may not work perfectly if you do.
      </p>
    </section>

    <section class="es-lg-section" id="third-parties" aria-labelledby="h-third">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-third" class="es-lg-h2">Third-party services</h2>
      <p class="es-lg-p">
        Depending on how you interact with us, data may be processed by providers such as: <strong>Meta</strong> (WhatsApp and Instagram), <strong>TikTok</strong>, shipping couriers operating in Perú, payment rails you choose (Yape, Plin, bank transfer), our email provider, and static hosting or DNS services. Each has its own privacy policy; we choose providers that align with our needs and, where possible, data processing terms appropriate for a small business in Perú.
      </p>
    </section>

    <section class="es-lg-section" id="your-rights" aria-labelledby="h-rights">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-rights" class="es-lg-h2">Your rights (ARCO and related)</h2>
      <p class="es-lg-p">
        Under Ley N° 29733, you generally have rights including <strong>access</strong> (know what we hold), <strong>rectification</strong> (correct inaccurate data), <strong>cancellation</strong> (delete when applicable), <strong>opposition</strong> (object to certain processing), <strong>information</strong> about use, and the ability to <strong>revoke consent</strong> where processing is consent-based — subject to legal exceptions (for example, data we must retain for tax or contractual reasons).
      </p>
      <p class="es-lg-p">
        To exercise these rights, contact us using the channel at the end of this page. You may also file a complaint with the <strong>Autoridad Nacional de Protección de Datos Personales</strong> if you believe your rights have been infringed, in accordance with current Peruvian procedures.
      </p>
    </section>

    <section class="es-lg-section" id="retention" aria-labelledby="h-retention">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-retention" class="es-lg-h2">Retention</h2>
      <p class="es-lg-p">
        We keep information only as long as needed for the purposes above. Order and invoicing records may be retained for periods required by <em>normativa tributaria y contable</em> in Perú. Booking and consultation records are typically kept for a limited period (for example, around twelve months after your last relevant contact) unless a longer period is justified for disputes or legal compliance. WhatsApp and messaging history depends on your and the platform’s settings; we do not promise indefinite storage of chats.
      </p>
    </section>

    <section class="es-lg-section" id="security" aria-labelledby="h-security">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-security" class="es-lg-h2">Security</h2>
      <p class="es-lg-p">
        We implement reasonable technical and organizational measures appropriate to the size of our operation — including access control, careful handling of messages, and secure connections where offered by our providers. No method of transmission over the internet is completely secure; we will notify you of a personal data breach when required by applicable law.
      </p>
    </section>

    <section class="es-lg-section" id="minors" aria-labelledby="h-minors">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-minors" class="es-lg-h2">Minors</h2>
      <p class="es-lg-p">
        Our services are intended for adults <strong>18 years or older</strong>. We do not knowingly collect personal data from minors. If you believe a minor has provided us data, contact us and we will take steps to delete it where appropriate.
      </p>
    </section>

    <section class="es-lg-section" id="changes" aria-labelledby="h-changes">
      <span class="es-lg-section__num" aria-hidden="true"></span>
      <h2 id="h-changes" class="es-lg-h2">Changes to this policy</h2>
      <p class="es-lg-p">
        We may update this policy to reflect changes in our practices or the law. The “Last updated” date at the top shows the current version. Material changes will be posted on this page; continued use of the site after updates constitutes your acknowledgment of the revised policy where permitted by law.
      </p>
    </section>

    <aside class="es-lg-contact" aria-labelledby="contact-privacy-heading">
      <p class="es-lg-contact__label" id="contact-privacy-heading">Questions</p>
      <h2 class="es-lg-contact__title">Privacy &amp; data requests</h2>
      <p class="es-lg-contact__text">
        Message us on WhatsApp for ARCO requests or general privacy questions. We respond as promptly as our small team allows.
      </p>
      <a
        class="es-lg-contact__link"
        href="https://wa.me/51919623179?text=Hola%20Esoterica%20%E2%80%94%20tengo%20una%20pregunta%20sobre%20privacidad."
        target="_blank"
        rel="noopener noreferrer"
      >
        Open WhatsApp
      </a>
    </aside>
  </article>

  <script is:inline slot="scripts">
    (function () {
      if (typeof gsap === 'undefined') return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      gsap.registerPlugin(ScrollTrigger);

      const ease = 'power3.out';
      const ruleOrigin = document.body.classList.contains('pg-terms') ? 'right center' : 'left center';

      gsap.timeline({ defaults: { ease } })
        .from('.es-lg-crumb li', { opacity: 0, y: 10, duration: 0.45, stagger: 0.07 }, 0.2)
        .from('.es-lg-rule', { scaleX: 0, duration: 0.5, transformOrigin: ruleOrigin }, 0.35)
        .from('.es-lg-title', { opacity: 0, y: 22, duration: 0.65 }, 0.45)
        .from('.es-lg-lede', { opacity: 0, y: 16, duration: 0.55 }, 0.65)
        .from('.es-lg-meta', { opacity: 0, y: 10, duration: 0.45 }, 0.8);

      gsap.from('.es-lg-toc', {
        opacity: 0,
        y: 20,
        duration: 0.65,
        ease,
        scrollTrigger: {
          trigger: '.es-lg-toc',
          start: 'top 88%',
          toggleActions: 'play none none none',
        },
      });

      document.querySelectorAll('.es-lg-section').forEach(function (section) {
        const num = section.querySelector('.es-lg-section__num');
        const h2 = section.querySelector('.es-lg-h2');
        const bodyEls = section.querySelectorAll('.es-lg-p, .es-lg-list, .es-lg-h3, .es-lg-note');
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: 'top 82%',
            toggleActions: 'play none none none',
          },
        });
        if (num) tl.from(num, { x: -12, opacity: 0, duration: 0.45, ease });
        if (h2) tl.from(h2, { y: 18, opacity: 0, duration: 0.55, ease }, num ? '-=0.2' : 0);
        if (bodyEls.length)
          tl.from(bodyEls, { y: 14, opacity: 0, duration: 0.5, stagger: 0.08, ease }, '-=0.15');
      });

      gsap.from('.es-lg-contact', {
        opacity: 0,
        y: 24,
        duration: 0.8,
        ease,
        scrollTrigger: {
          trigger: '.es-lg-contact',
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      });
    })();
  </script>
</Layout>
