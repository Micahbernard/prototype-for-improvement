---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
/* ===== BARE HERO (terms) ===== */
        .pg-bare-hero {
            padding: 8rem 3rem 4rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .pg-bare-hero-inner {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 1.25rem;
        }
        .pg-bare-rule {
            width: 60px;
            height: 1px;
            background: linear-gradient(90deg, var(--es-gold), transparent);
            margin: 0.5rem 0;
        }
        .pg-bare-title {
            font-size: clamp(3rem, 7vw, 5.5rem) !important;
            font-weight: 400 !important;
            letter-spacing: 0.02em;
            line-height: 1 !important;
            text-align: left !important;
            margin: 0 !important;
            max-width: none !important;
        }
        body.pg-terms .hero-subtitle {
            font-family: var(--es-font-serif);
            font-size: 1rem;
            font-style: italic;
            color: var(--es-text-faint);
            margin: 0;
        }
        body.pg-terms .hero-breadcrumb {
            font-size: 0.65rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--es-text-dim);
        }
        body.pg-terms .hero-breadcrumb a {
            color: var(--es-text-faint);
            text-decoration: none;
        }
        body.pg-terms .pg-bare-hero {
            display: flex;
            justify-content: flex-end;
        }
        body.pg-terms .pg-bare-hero-inner {
            align-items: flex-end;
            text-align: right;
        }
        body.pg-terms .pg-bare-rule {
            background: linear-gradient(270deg, var(--es-gold), transparent);
            align-self: flex-end;
        }
        body.pg-terms .pg-bare-title {
            text-align: right !important;
        }

        /* ===== SECTION SHARED ===== */
        /* inner-page override */
        .section {
            padding: 6rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        /* inner-page override */
        .section-divider {
            width: 60px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--es-gold), transparent);
            margin: 0 auto 2rem;
        }

        /* inner-page override */
        .section-label {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 1rem;
        }

        /* inner-page override */
        .section-description {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            text-align: center;
            max-width: var(--es-max-prose);
            margin: 0 auto 3rem;
        }

        /* ===== CLASS CARDS GRID ===== */
        .classes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .class-card {
            background: var(--es-bg-card-soft);
            border: 1px solid var(--es-border-card);
            border-radius: var(--es-radius-card-sm);
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
            cursor: pointer;
        }

        .class-card:hover {
            transform: translateY(-6px);
            border-color: var(--es-border-card-hover);
            box-shadow: var(--es-shadow-card-hover);
        }

        .class-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 20%, rgba(100, 60, 180, 0.08) 0%, transparent 60%);
            pointer-events: none;
        }

        .class-icon {
            font-size: 2.5rem;
            margin-bottom: 1.2rem;
            display: block;
            color: var(--es-gold);
        }

        .class-icon svg {
            display: block;
            margin: 0 auto;
        }

        .class-badge {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            margin-bottom: 1rem;
        }

        .class-name {
            font-family: 'Cinzel', serif;
            font-size: 1.3rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .class-type {
            font-family: 'Inter', sans-serif;
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-gold);
            margin-bottom: 1rem;
        }

        .class-desc {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: rgba(var(--es-text-rgb), 0.68);
            margin-bottom: 1.5rem;
        }

        .class-details {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            color: var(--es-text-faint);
            margin-bottom: 1.5rem;
            line-height: 1.8;
        }

        .class-price {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--es-gold);
            margin-bottom: 1.5rem;
        }

        .class-cta {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
        }

        .class-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(212, 168, 83, 0.25);
        }

        /* ===== FORMAT SECTION ===== */
        .format-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2.5rem;
            text-align: center;
        }

        .format-item {
            position: relative;
        }

        .format-icon {
            font-size: 2rem;
            color: rgba(var(--es-gold-rgb), 0.6);
            margin-bottom: 1rem;
        }

        .format-title {
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            font-weight: 500;
            margin-bottom: 0.6rem;
        }

        .format-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.95rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: var(--es-text-faint);
        }

        /* ===== QUOTE ===== */
        /* inner-page override */
        .quote-section {
            text-align: center;
            padding: 5rem 2rem;
        }

        /* inner-page override */
        .quote-mark {
            font-family: 'Cinzel', serif;
            font-size: 5rem;
            line-height: 1;
            color: rgba(var(--es-gold-rgb), 0.15);
        }

        /* inner-page override */
        .quote-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.2rem, 2.5vw, 1.6rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-subtle);
            max-width: 600px;
            margin: 0 auto 1rem;
        }

        /* inner-page override */
        .quote-author {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-text-dim);
        }
</style>

<Layout title="Terms of Use — Esoterica" description="Terms of Use — Esoterica." bodyClass="pg-terms">
  <div slot="chrome">
  <div class="cursor-rune" aria-hidden="true">
    <div class="cursor-rune-ripple"></div>
    <div class="cursor-rune-ring">
      <div class="cursor-rune-h"></div>
      <div class="cursor-rune-v"></div>
      <div class="cursor-rune-center"></div>
    </div>
  </div>
  <canvas id="starfield"></canvas>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  </div>

<section class="pg-bare-hero">
  <div class="pg-bare-hero-inner">
    <div class="hero-breadcrumb">
      <a href="/">Home</a> &nbsp;/&nbsp; Terms of Use
    </div>
    <div class="pg-bare-rule"></div>
    <h1 class="hero-title pg-bare-title">Terms of Use</h1>
    <p class="hero-subtitle">The rules of this threshold.</p>
  </div>
</section>
  <script is:inline slot="scripts">
/* ===== STARFIELD ===== */
        (function () {
            const canvas = document.getElementById('starfield');
            const ctx = canvas.getContext('2d');
            let stars = [];
            const STAR_COUNT = 120;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }

            function init() {
                stars = Array.from({ length: STAR_COUNT }, () => ({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: Math.random() * 1.2 + 0.3,
                    alpha: Math.random() * 0.6 + 0.1,
                    speed: Math.random() * 0.008 + 0.004,
                    phase: Math.random() * Math.PI * 2,
                }));
            }

            function draw(t) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                stars.forEach(s => {
                    const a = s.alpha * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(232,224,212,${a})`;
                    ctx.fill();
                });
                requestAnimationFrame(draw);
            }

            resize();
            init();
            window.addEventListener('resize', () => { resize(); init(); });
            requestAnimationFrame(draw);
        })();

        /* ===== CUSTOM CURSOR ===== */
        (function () {
            const dot = document.querySelector('.cursor-rune');
            if (!dot) return;
            document.addEventListener('mousemove', e => {
                dot.style.left = e.clientX + 'px';
                dot.style.top = e.clientY + 'px';
            });
            const interactables = 'a, button, .class-card, .class-cta, .nav-link-block';
            document.querySelectorAll(interactables).forEach(el => {
                el.addEventListener('mouseenter', () => dot.classList.add('is-hover'));
                el.addEventListener('mouseleave', () => dot.classList.remove('is-hover'));
            });
            window.addEventListener('mousedown', () => dot.classList.add('is-click'));
            window.addEventListener('mouseup', () => dot.classList.remove('is-click'));
        })();

        /* ===== GSAP ANIMATIONS ===== */
        (function () {
            if (typeof gsap === 'undefined') return;

            gsap.registerPlugin(ScrollTrigger);

            gsap.from('.pg-bare-hero .hero-breadcrumb', { opacity: 0, y: 10, duration: 0.8, ease: 'power3.out', delay: 0.3 });
            gsap.from('.pg-bare-hero .pg-bare-rule', { opacity: 0, scaleX: 0, transformOrigin: 'right center', duration: 0.6, ease: 'power2.out', delay: 0.45 });
            gsap.from('.pg-bare-hero .hero-title', { opacity: 0, y: 20, duration: 1, ease: 'power3.out', delay: 0.55 });
            gsap.from('.pg-bare-hero .hero-subtitle', { opacity: 0, y: 15, duration: 0.8, ease: 'power3.out', delay: 0.75 });

            document.querySelectorAll('.class-card').forEach((card, i) => {
                gsap.from(card, {
                    scrollTrigger: { trigger: card, start: 'top 85%' },
                    opacity: 0, y: 30, duration: 0.7, ease: 'power3.out', delay: i * 0.08
                });
            });

            document.querySelectorAll('.format-item').forEach((item, i) => {
                gsap.from(item, {
                    scrollTrigger: { trigger: item, start: 'top 88%' },
                    opacity: 0, y: 20, duration: 0.6, ease: 'power2.out', delay: i * 0.1
                });
            });
        })();
  </script>
</Layout>
