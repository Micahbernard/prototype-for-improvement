---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
/* ===== HERO (inner .sub-hero-cosmos in styles.css) ===== */
        /* inner-page override */
        .page-hero {
            padding: 5.5rem 1.25rem 2.5rem;
            position: relative;
        }

        /* inner-page override */
        .hero-sigil {
            margin-bottom: 1.5rem;
        }

        /* inner-page override */
        .hero-sigil img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            object-position: center 58%;
            border-radius: 50%;
            filter: drop-shadow(0 0 16px rgba(212, 168, 83, 0.3)) drop-shadow(0 0 40px rgba(90, 50, 140, 0.15));
        }

        /* inner-page override */
        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 500;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            max-width: 700px;
        }

        /* inner-page override */
        .hero-subtitle {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.05rem, 1.8vw, 1.3rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            max-width: var(--es-max-prose);
            margin: 0 auto;
        }

        /* ===== SECTION SHARED ===== */
        /* inner-page override */
        .section {
            padding: 6rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        /* inner-page override */
        .section-divider {
            width: 60px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--es-gold), transparent);
            margin: 0 auto 2rem;
        }

        /* inner-page override */
        .section-label {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 1rem;
        }

        /* inner-page override */
        .section-description {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            text-align: center;
            max-width: var(--es-max-prose);
            margin: 0 auto 3rem;
        }

        /* ===== READING CARDS GRID ===== */
        .readings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 2rem;
        }

        .reading-card {
            background: var(--es-bg-card-soft);
            border: 1px solid var(--es-border-card);
            border-radius: var(--es-radius-card-sm);
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
        }

        .reading-card:hover {
            transform: translateY(-6px);
            border-color: var(--es-border-card-hover);
            box-shadow: var(--es-shadow-card-hover);
        }

        .reading-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 20%, rgba(100, 60, 180, 0.08) 0%, transparent 60%);
            pointer-events: none;
        }

        .reading-icon {
            font-size: 2.5rem;
            margin-bottom: 1.2rem;
            display: block;
            color: var(--es-gold);
        }

        .reading-icon svg {
            display: block;
            margin: 0 auto;
        }

        .reading-name {
            font-family: 'Cinzel', serif;
            font-size: 1.3rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .reading-type {
            font-family: 'Inter', sans-serif;
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-gold);
            margin-bottom: 1rem;
        }

        .reading-desc {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: var(--es-text-subtle);
            margin-bottom: 1.5rem;
            flex: 1;
        }

        .reading-details {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            color: var(--es-text-faint);
            margin-bottom: 1.5rem;
            line-height: 1.8;
        }

        .reading-price {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--es-gold);
            margin-bottom: 1.5rem;
        }

        .reading-cta {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .reading-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(212, 168, 83, 0.2);
        }

        .reading-card,
        .class-card {
            position: relative;
            overflow: hidden;
            height: 420px;
            z-index: 0;
        }

        .reading-card-reveal,
        .class-card-reveal {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 2rem 1.75rem 1.75rem;
            background: linear-gradient(
                to top,
                var(--es-bg-card) 0%,
                var(--es-bg-card) 75%,
                transparent 100%
            );
            transform: translateY(100%);
            transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            border-top: 1px solid color-mix(in srgb, var(--es-gold) 18%, transparent);
            backdrop-filter: blur(0px);
        }

        .reading-card:hover .reading-card-reveal,
        .class-card:hover .class-card-reveal {
            transform: translateY(0);
        }

        .reading-card-body,
        .class-card-body {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        /* ===== HOW IT WORKS (scroll timeline) ===== */
        .how-timeline {
            position: relative;
            max-width: 680px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .how-timeline-line {
            position: absolute;
            left: 2.5rem;
            top: 0;
            bottom: 0;
            width: 1px;
            background: color-mix(in srgb, var(--es-gold) 12%, transparent);
        }

        .how-timeline-progress {
            width: 100%;
            height: 0%;
            background: linear-gradient(180deg, var(--es-gold), var(--es-violet));
            transition: height 0.1s linear;
        }

        .how-step {
            display: grid;
            grid-template-columns: 5rem 1fr;
            gap: 2rem;
            padding: 3rem 0;
            border-bottom: 1px solid color-mix(in srgb, var(--es-gold) 8%, transparent);
            opacity: 0.35;
            transition: opacity 0.5s ease;
        }

        .how-step.is-active {
            opacity: 1;
        }

        .how-step:last-child {
            border-bottom: none;
        }

        .how-step-number {
            font-family: var(--es-font-display);
            font-size: 3.5rem;
            font-weight: 400;
            color: var(--es-gold);
            opacity: 0.25;
            line-height: 1;
            transition: opacity 0.5s ease, transform 0.5s ease;
            transform: translateY(4px);
            padding-top: 0.25rem;
        }

        .how-step.is-active .how-step-number {
            opacity: 1;
            transform: translateY(0);
        }

        .how-step-content {
            padding-top: 0.5rem;
        }

        .how-title {
            font-family: var(--es-font-display);
            font-size: 1.1rem;
            font-weight: 500;
            letter-spacing: 0.05em;
            color: var(--es-white);
            margin-bottom: 0.75rem;
        }

        .how-text {
            font-family: var(--es-font-serif);
            font-size: 1.05rem;
            font-weight: 300;
            line-height: 1.8;
            color: var(--es-text-muted);
        }

        @media (max-width: 768px) {
            .how-timeline-line {
                display: none;
            }

            .how-step {
                grid-template-columns: 3rem 1fr;
                gap: 1rem;
                opacity: 1;
            }

            .how-step-number {
                font-size: 2rem;
                opacity: 0.5;
            }
        }

        /* ===== TESTIMONIALS ===== */
        /* inner-page override */
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        /* inner-page override */
        .testimonial-card {
            background: rgba(15, 11, 36, 0.5);
            border: 1px solid rgba(120, 80, 180, 0.08);
            border-radius: 12px;
            padding: 2rem;
        }

        .testimonial-quote {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.05rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-subtle);
            margin-bottom: 1.2rem;
        }

        /* inner-page override */
        .testimonial-author {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-text-dim);
        }

        /* ===== QUOTE ===== */
        /* inner-page override */
        .quote-section {
            text-align: center;
            padding: 5rem 2rem;
        }

        /* inner-page override */
        .quote-mark {
            font-family: 'Cinzel', serif;
            font-size: 5rem;
            line-height: 1;
            color: rgba(var(--es-gold-rgb), 0.15);
        }

        /* inner-page override */
        .quote-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.2rem, 2.5vw, 1.6rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-subtle);
            max-width: 600px;
            margin: 0 auto 1rem;
        }

        /* inner-page override */
        .quote-author {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-text-dim);
        }

        /* ===== CURSOR ===== */
        .reading-card {
            cursor: pointer;
        }

        .reading-cta {
            cursor: pointer;
        }

        /* ===== WILL-CHANGE (GPU performance) ===== */
        .reading-card {
            will-change: transform;
        }

        /* inner-page override */
        .orb {
            will-change: transform;
        }

        /* ===== MOBILE ===== */
        @media (max-width: 768px) {
            /* inner-page override */
            .nav {
                padding: 1rem 1.5rem;
            }

            .readings-grid {
                grid-template-columns: 1fr;
            }
        }
</style>

