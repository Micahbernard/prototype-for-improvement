---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tarot Readings — Esoterica"
  description="Intuitive tarot readings channeled through the mystic arts. Discover clarity, guidance, and cosmic insight."
  bodyClass="pg-tarot"
>

<!-- ===== HERO ===== -->
        <section class="es-th-hero">
            <div class="es-th-hero__inner">
                <div class="es-th-copy">
                    <nav class="es-th-crumb" aria-label="Breadcrumb">
                        <ol>
                            <li><a href="/">Home</a></li>
                            <li><span aria-current="page">Tarot Readings</span></li>
                        </ol>
                    </nav>
                    <div class="es-th-rule" aria-hidden="true"></div>
                    <h1 class="es-th-title">The Cards Remember What You've Forgotten</h1>
                    <p class="es-th-lede">
                        Each reading is a mirror held to the soul — revealing patterns, illuminating crossroads, and whispering truths your conscious mind may overlook.
                    </p>
                </div>
                <div class="es-th-spread" aria-hidden="true">
                    <div class="es-th-card es-th-card--left">
                        <div class="es-th-card__sigil">
                            <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.2">
                                <circle cx="20" cy="20" r="10"></circle>
                                <path d="M20 5 L20 12 M20 28 L20 35 M5 20 L12 20 M28 20 L35 20"></path>
                            </svg>
                        </div>
                    </div>
                    <div class="es-th-card es-th-card--center">
                        <div class="es-th-card__sigil">
                            <svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.3">
                                <ellipse cx="30" cy="30" rx="24" ry="12"></ellipse>
                                <circle cx="30" cy="30" r="6" fill="currentColor" fill-opacity="0.35"></circle>
                                <circle cx="30" cy="30" r="2.5" fill="currentColor"></circle>
                                <path d="M30 6 L30 12 M30 48 L30 54 M6 30 L12 30 M48 30 L54 30" opacity="0.6"></path>
                            </svg>
                        </div>
                    </div>
                    <div class="es-th-card es-th-card--right">
                        <div class="es-th-card__sigil">
                            <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.2">
                                <path d="M20 6 L23.5 16.5 L34 16.5 L25.5 23 L29 33.5 L20 27 L11 33.5 L14.5 23 L6 16.5 L16.5 16.5 Z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== READINGS GRID ===== -->
        <section class="section" id="readings">
            <div class="section-divider"></div>
            <p class="section-label">Choose Your Path</p>
            <h2 class="section-heading">Sacred Readings</h2>
            <p class="section-description">
                Every reading is performed intuitively, guided by the energy you bring and the questions your spirit
                yearns to answer.
            </p>

            <div class="readings-grid">
                <div class="reading-card">
                    <div class="reading-card-body">
                        <span class="reading-icon" aria-hidden="true"><svg width="40" height="40" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
                            </svg></span>
                        <h3 class="reading-name">Celtic Cross</h3>
                        <p class="reading-type">Deep Guidance</p>
                        <p class="reading-desc">The ancient 10-card spread that maps your past, present, and future. Reveals
                            hidden influences and the path of highest potential.</p>
                        <div class="reading-card-reveal">
                            <div class="reading-details">
                                10 Cards · 60 min session<br>
                                Written summary included
                            </div>
                            <p class="reading-price">$95</p>
                            <a class="reading-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20lectura%20Celtic%20Cross." target="_blank" rel="noopener noreferrer">Book Reading</a>
                        </div>
                    </div>
                </div>

                <div class="reading-card">
                    <div class="reading-card-body">
                        <span class="reading-icon" aria-hidden="true"><svg width="40" height="40" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10" />
                                <circle cx="12" cy="12" r="4" />
                                <line x1="12" y1="2" x2="12" y2="6" />
                                <line x1="12" y1="18" x2="12" y2="22" />
                                <line x1="2" y1="12" x2="6" y2="12" />
                                <line x1="18" y1="12" x2="22" y2="12" />
                            </svg></span>
                        <h3 class="reading-name">Past Life</h3>
                        <p class="reading-type">Soul Archaeology</p>
                        <p class="reading-desc">A specialized spread that peers through the veil of time, uncovering karmic
                            patterns and soul contracts from previous incarnations.</p>
                        <div class="reading-card-reveal">
                            <div class="reading-details">
                                7 Cards · 45 min session<br>
                                Past life meditation included
                            </div>
                            <p class="reading-price">$120</p>
                            <a class="reading-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20lectura%20Past%20Life." target="_blank" rel="noopener noreferrer">Book Reading</a>
                        </div>
                    </div>
                </div>

                <div class="reading-card">
                    <div class="reading-card-body">
                        <span class="reading-icon" aria-hidden="true"><svg width="40" height="40" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path d="M12 2c.5 3-2.5 5.5-2 8.5.5 3 3.5 4.5 3.5 4.5s3-1.5 3.5-4.5c.5-3-2.5-5.5-2-8.5" />
                                <path d="M9 17h6" />
                                <path d="M10 20h4" />
                                <path d="M11 22h2" />
                            </svg></span>
                        <h3 class="reading-name">Shadow Work</h3>
                        <p class="reading-type">Inner Alchemy</p>
                        <p class="reading-desc">Confront the unconscious. This reading illuminates your shadow self — the
                            parts hidden from sight that hold the keys to transformation.</p>
                        <div class="reading-card-reveal">
                            <div class="reading-details">
                                5 Cards · 40 min session<br>
                                Integration ritual guide
                            </div>
                            <p class="reading-price">$75</p>
                            <a class="reading-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20lectura%20Shadow%20Work." target="_blank" rel="noopener noreferrer">Book Reading</a>
                        </div>
                    </div>
                </div>

                <div class="reading-card">
                    <div class="reading-card-body">
                        <span class="reading-icon" aria-hidden="true"><svg width="40" height="40" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <polygon
                                    points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                            </svg></span>
                        <h3 class="reading-name">Cosmic Love</h3>
                        <p class="reading-type">Heart Cartography</p>
                        <p class="reading-desc">Whether seeking connection or deepening an existing bond, this spread maps
                            the terrain of your heart's truest desires.</p>
                        <div class="reading-card-reveal">
                            <div class="reading-details">
                                6 Cards · 45 min session<br>
                                Love spell candle included
                            </div>
                            <p class="reading-price">$85</p>
                            <a class="reading-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20lectura%20Cosmic%20Love." target="_blank" rel="noopener noreferrer">Book Reading</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== QUOTE ===== -->
        <section class="quote-section">
            <div class="quote-mark">"</div>
            <p class="quote-text">The cards do not predict the future — they illuminate the choices that create it.</p>
            <p class="quote-author">— The Keeper of Veils</p>
        </section>

        <!-- ===== HOW IT WORKS ===== -->
        <section class="section" id="how">
            <div class="section-divider"></div>
            <p class="section-label">The Sacred Process</p>
            <h2 class="section-heading">How It Works</h2>
            <p class="section-description">
                From booking to revelation, every step is held with intention and care.
            </p>

            <div class="how-timeline">
                <div class="how-timeline-line"><div class="how-timeline-progress"></div></div>
                <div class="how-step" data-step="I">
                    <div class="how-step-number">I</div>
                    <div class="how-step-content">
                        <h3 class="how-title">Set Your Intention</h3>
                        <p class="how-text">Choose your reading type and share what weighs on your heart. Your question shapes the lens through which the cards speak.</p>
                    </div>
                </div>
                <div class="how-step" data-step="II">
                    <div class="how-step-number">II</div>
                    <div class="how-step-content">
                        <h3 class="how-title">The Channeling</h3>
                        <p class="how-text">Your reader enters a meditative state, shuffling the deck while holding your energy. The cards fall where they must.</p>
                    </div>
                </div>
                <div class="how-step" data-step="III">
                    <div class="how-step-number">III</div>
                    <div class="how-step-content">
                        <h3 class="how-title">The Unveiling</h3>
                        <p class="how-text">Each card is revealed and interpreted in the context of your question. Patterns emerge. Truths crystallize.</p>
                    </div>
                </div>
                <div class="how-step" data-step="IV">
                    <div class="how-step-number">IV</div>
                    <div class="how-step-content">
                        <h3 class="how-title">Integration</h3>
                        <p class="how-text">Receive your written summary, recommended rituals, and guidance for weaving the reading's wisdom into your daily life.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== TESTIMONIALS ===== -->
        <section class="section" id="testimonials">
            <div class="section-divider"></div>
            <p class="section-label">Voices from the Veil</p>
            <h2 class="section-heading">What Seekers Say</h2>
            <p class="section-description">
                Words from those who dared to look beyond the surface.
            </p>

            <div class="testimonials-grid">
                <div class="testimonial-card">
                    <p class="testimonial-quote">"The Celtic Cross reading shook me to my core. Cards that a stranger
                        pulled somehow knew the exact crossroads I was standing at. I've never felt so seen."</p>
                    <p class="testimonial-author">— Luna M.</p>
                </div>
                <div class="testimonial-card">
                    <p class="testimonial-quote">"My past life reading revealed a pattern I've been repeating for
                        decades without realizing. The clarity was immediate and profound."</p>
                    <p class="testimonial-author">— Sage R.</p>
                </div>
                <div class="testimonial-card">
                    <p class="testimonial-quote">"I was skeptical, honestly. But the shadow work reading named things I
                        hadn't told anyone. The integration ritual changed my journaling practice forever."</p>
                    <p class="testimonial-author">— Ember K.</p>
                </div>
            </div>
        </section>
  <script is:inline slot="scripts">
        /* ================================================================
           GSAP SCROLL ANIMATIONS
        ================================================================ */
        document.addEventListener("DOMContentLoaded", function () {
            gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

            if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                gsap.set('.es-th-card--left', { x: 0, y: 0, rotation: 0, opacity: 0 });
                gsap.set('.es-th-card--right', { x: 0, y: 0, rotation: 0, opacity: 0 });
                gsap.set('.es-th-card--center', { y: 0, opacity: 0 });

                const tlHero = gsap.timeline({
                    delay: 0.15,
                    onComplete: () => {
                        gsap.set('.es-th-card--center', { clearProps: 'transform' });
                    },
                });
                tlHero
                    .to('.es-th-card--center', { opacity: 1, y: -24, duration: 0.9, ease: 'power3.out' })
                    .to('.es-th-card--left', { opacity: 1, x: -70, y: 20, rotation: -8, duration: 0.9, ease: 'power3.out' }, '-=0.55')
                    .to('.es-th-card--right', { opacity: 1, x: 70, y: 20, rotation: 8, duration: 0.9, ease: 'power3.out' }, '-=0.9')
                    .from('.es-th-crumb', { opacity: 0, x: -12, duration: 0.6, ease: 'power2.out' }, '-=0.5')
                    .from('.es-th-rule', { opacity: 0, scaleX: 0, transformOrigin: 'left center', duration: 0.5, ease: 'power2.out' }, '-=0.4')
                    .from('.es-th-title', { opacity: 0, y: 20, duration: 0.9, ease: 'power3.out' }, '-=0.3')
                    .from('.es-th-lede', { opacity: 0, y: 15, duration: 0.7, ease: 'power3.out' }, '-=0.55');

                gsap.to('.es-th-spread', {
                    y: 40,
                    ease: 'none',
                    scrollTrigger: {
                        trigger: '.es-th-hero',
                        start: 'top top',
                        end: 'bottom top',
                        scrub: 1,
                    },
                });
            }

            // Fade-up all sections
            document.querySelectorAll('.section, .quote-section').forEach(section => {
                const els = section.querySelectorAll('.section-divider, .section-label, .section-heading, .section-description, .how-step, .testimonial-card, .quote-mark, .quote-text, .quote-author');
                els.forEach((el, i) => {
                    gsap.from(el, {
                        y: 50,
                        opacity: 0,
                        duration: 0.8,
                        delay: i * 0.08,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: el,
                            start: "top 88%",
                            toggleActions: "play none none none"
                        }
                    });
                });
            });

            (function initReadingGridReveal() {
                if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
                document.querySelectorAll('.readings-grid').forEach(grid => {
                    const cards = grid.querySelectorAll('.reading-card');
                    if (!cards.length) return;
                    gsap.from(cards, {
                        y: 50,
                        opacity: 0,
                        duration: 0.9,
                        stagger: 0.12,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: grid,
                            start: "top 78%",
                            toggleActions: "play none none none"
                        }
                    });
                });
            })();

            document.querySelectorAll('.reading-card').forEach(card => {
                const cta = card.querySelector('.reading-cta');
                card.addEventListener('mouseenter', () => {
                    gsap.to(card, { y: -6, scale: 1.02, duration: 0.35, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.22em', duration: 0.3, ease: 'power2.out' });
                });
                card.addEventListener('mouseleave', () => {
                    gsap.to(card, { y: 0, scale: 1, duration: 0.5, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.15em', duration: 0.3, ease: 'power2.out' });
                });
            });

            // Bracket hover animations
            document.querySelectorAll('.nav-link-block').forEach(link => {
                const bracketL = link.querySelector('.bracket-left');
                const bracketR = link.querySelector('.bracket-right');
                const textOrig = link.querySelector('.text-nav:not(.is-duplicate)');
                const textDup = link.querySelector('.text-nav.is-duplicate');

                if (!bracketL || !bracketR || !textOrig || !textDup) return;

                gsap.set(bracketL, { x: '1rem', opacity: 0 });
                gsap.set(bracketR, { x: '-1rem', opacity: 0 });
                gsap.set(textDup, { y: '120%' });

                link.addEventListener('mouseenter', () => {
                    gsap.to(bracketL, { x: 0, opacity: 1, duration: 0.3, ease: 'power2.out' });
                    gsap.to(bracketR, { x: 0, opacity: 1, duration: 0.3, ease: 'power2.out' });
                    gsap.to(textOrig, { y: '-120%', duration: 0.35, ease: 'power2.inOut' });
                    gsap.to(textDup, { y: 0, duration: 0.35, ease: 'power2.inOut' });
                });

                link.addEventListener('mouseleave', () => {
                    gsap.to(bracketL, { x: '1rem', opacity: 0, duration: 0.3, ease: 'power2.out' });
                    gsap.to(bracketR, { x: '-1rem', opacity: 0, duration: 0.3, ease: 'power2.out' });
                    gsap.to(textOrig, { y: 0, duration: 0.35, ease: 'power2.inOut' });
                    gsap.to(textDup, { y: '120%', duration: 0.35, ease: 'power2.inOut' });
                });
            });

            // Timeline scroll activation
            const steps = document.querySelectorAll('.how-step');
            const progressBar = document.querySelector('.how-timeline-progress');

            if (steps.length && progressBar) {
                steps.forEach(step => {
                    ScrollTrigger.create({
                        trigger: step,
                        start: 'top 60%',
                        end: 'bottom 40%',
                        onEnter: () => step.classList.add('is-active'),
                        onLeave: () => step.classList.remove('is-active'),
                        onEnterBack: () => step.classList.add('is-active'),
                        onLeaveBack: () => step.classList.remove('is-active'),
                    });
                });

                // Progress line grows as you scroll through the timeline
                const timeline = document.querySelector('.how-timeline');
                if (timeline) {
                    gsap.to(progressBar, {
                        height: '100%',
                        ease: 'none',
                        scrollTrigger: {
                            trigger: timeline,
                            start: 'top 65%',
                            end: 'bottom 55%',
                            scrub: 0.5
                        }
                    });
                }
            }
        });
  </script>
</Layout>
