  <script is:inline slot="scripts">
/* ================================================================
           STARFIELD — Same as main site
        ================================================================ */
        (function () {
            const canvas = document.getElementById('starfield');
            const ctx = canvas.getContext('2d');
            let stars = [];
            const STAR_COUNT = 180;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resize);
            resize();

            function createStars() {
                stars = [];
                for (let i = 0; i < STAR_COUNT; i++) {
                    stars.push({
                        x: Math.random() * canvas.width,
                        y: Math.random() * canvas.height,
                        r: Math.random() * 1.5 + 0.3,
                        alpha: Math.random(),
                        speed: Math.random() * 0.005 + 0.001,
                        phase: Math.random() * Math.PI * 2
                    });
                }
            }
            createStars();

            function drawStars(time) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                const grd = ctx.createRadialGradient(
                    canvas.width * 0.3, canvas.height * 0.4, 0,
                    canvas.width * 0.3, canvas.height * 0.4, canvas.width * 0.5
                );
                grd.addColorStop(0, 'rgba(60, 20, 100, 0.03)');
                grd.addColorStop(1, 'transparent');
                ctx.fillStyle = grd;
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                for (const star of stars) {
                    const twinkle = Math.sin(time * star.speed + star.phase) * 0.5 + 0.5;
                    const alpha = star.alpha * twinkle * 0.8 + 0.1;

                    ctx.beginPath();
                    ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(232, 224, 212, ${alpha})`;
                    ctx.fill();

                    if (star.r > 1.2) {
                        ctx.beginPath();
                        ctx.arc(star.x, star.y, star.r * 3, 0, Math.PI * 2);
                        ctx.fillStyle = `rgba(160, 130, 200, ${alpha * 0.08})`;
                        ctx.fill();
                    }
                }
                requestAnimationFrame(drawStars);
            }
            requestAnimationFrame(drawStars);
        })();

        /* ================================================================
           GSAP SCROLL ANIMATIONS
        ================================================================ */
        document.addEventListener("DOMContentLoaded", function () {
            gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

            // Native smooth scroll — no Lenis needed on this page

            // Fade-up all sections
            document.querySelectorAll('.section, .quote-section').forEach(section => {
                const els = section.querySelectorAll('.section-divider, .section-label, .section-heading, .section-description, .how-step, .testimonial-card, .quote-mark, .quote-text, .quote-author');
                els.forEach((el, i) => {
                    gsap.from(el, {
                        y: 50,
                        opacity: 0,
                        duration: 0.8,
                        delay: i * 0.08,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: el,
                            start: "top 88%",
                            toggleActions: "play none none none"
                        }
                    });
                });
            });

            (function initReadingGridReveal() {
                if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
                document.querySelectorAll('.readings-grid').forEach(grid => {
                    const cards = grid.querySelectorAll('.reading-card');
                    if (!cards.length) return;
                    gsap.from(cards, {
                        y: 50,
                        opacity: 0,
                        duration: 0.9,
                        stagger: 0.12,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: grid,
                            start: "top 78%",
                            toggleActions: "play none none none"
                        }
                    });
                });
            })();

            document.querySelectorAll('.reading-card').forEach(card => {
                const cta = card.querySelector('.reading-cta');
                card.addEventListener('mouseenter', () => {
                    gsap.to(card, { y: -6, scale: 1.02, duration: 0.35, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.22em', duration: 0.3, ease: 'power2.out' });
                });
                card.addEventListener('mouseleave', () => {
                    gsap.to(card, { y: 0, scale: 1, duration: 0.5, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.15em', duration: 0.3, ease: 'power2.out' });
                });
            });

            // Hero fade in
            gsap.from('.page-hero .hero-sigil', { y: 30, opacity: 0, duration: 1, delay: 0.3, ease: 'power3.out' });
            gsap.from('.page-hero .hero-breadcrumb', { y: 30, opacity: 0, duration: 1, delay: 0.5, ease: 'power3.out' });
            gsap.from('.page-hero .hero-title', { y: 40, opacity: 0, duration: 1.2, delay: 0.6, ease: 'power3.out' });
            gsap.from('.page-hero .hero-subtitle', { y: 40, opacity: 0, duration: 1.2, delay: 0.8, ease: 'power3.out' });

            // Sub-hero parallax depth
            if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
                const subHero = document.querySelector(".sub-hero-cosmos");
                const subHeroInner = document.querySelector(".sub-hero-cosmos-inner");
                const subHeroSigil = document.querySelector(".hero-sigil");
                const subHeroBefore = document.querySelector(".sub-hero-cosmos");

                if (subHero && subHeroInner) {
                    // Layer 1 — background glow (slowest, 15% scroll rate)
                    gsap.to(subHero, {
                        backgroundPositionY: "30%",
                        ease: "none",
                        scrollTrigger: {
                            trigger: subHero,
                            start: "top top",
                            end: "bottom top",
                            scrub: true
                        }
                    });

                    // Layer 2 — sigil logo (medium, 25% scroll rate)
                    if (subHeroSigil) {
                        gsap.to(subHeroSigil, {
                            y: -40,
                            ease: "none",
                            scrollTrigger: {
                                trigger: subHero,
                                start: "top top",
                                end: "bottom top",
                                scrub: true
                            }
                        });
                    }

                    // Layer 3 — text content (fastest, 45% scroll rate)
                    gsap.to(subHeroInner, {
                        y: -70,
                        opacity: 0,
                        ease: "none",
                        scrollTrigger: {
                            trigger: subHero,
                            start: "top top",
                            end: "60% top",
                            scrub: true
                        }
                    });
                }
            }

            // Bracket hover animations
            document.querySelectorAll('.nav-link-block').forEach(link => {
                const bracketL = link.querySelector('.bracket-left');
                const bracketR = link.querySelector('.bracket-right');
                const textOrig = link.querySelector('.text-nav:not(.is-duplicate)');
                const textDup = link.querySelector('.text-nav.is-duplicate');

                if (!bracketL || !bracketR || !textOrig || !textDup) return;

                gsap.set(bracketL, { x: '1rem', opacity: 0 });
                gsap.set(bracketR, { x: '-1rem', opacity: 0 });
                gsap.set(textDup, { y: '120%' });

                link.addEventListener('mouseenter', () => {
                    gsap.to(bracketL, { x: 0, opacity: 1, duration: 0.3, ease: 'power2.out' });
                    gsap.to(bracketR, { x: 0, opacity: 1, duration: 0.3, ease: 'power2.out' });
                    gsap.to(textOrig, { y: '-120%', duration: 0.35, ease: 'power2.inOut' });
                    gsap.to(textDup, { y: 0, duration: 0.35, ease: 'power2.inOut' });
                });

                link.addEventListener('mouseleave', () => {
                    gsap.to(bracketL, { x: '1rem', opacity: 0, duration: 0.3, ease: 'power2.out' });
                    gsap.to(bracketR, { x: '-1rem', opacity: 0, duration: 0.3, ease: 'power2.out' });
                    gsap.to(textOrig, { y: 0, duration: 0.35, ease: 'power2.inOut' });
                    gsap.to(textDup, { y: '120%', duration: 0.35, ease: 'power2.inOut' });
                });
            });

            /* ---- Radiant Orb Cursor (desktop only, no lag) ---- */
            if (window.matchMedia("(pointer: fine)").matches) {
                const dot = document.querySelector(".cursor-dot");

                // Direct 1:1 hardware cursor following (instant)
                window.addEventListener("mousemove", (e) => {
                    dot.style.transform = `translate(${e.clientX}px, ${e.clientY}px) translate(-50%, -50%)`;
                });

                // Simple hover state (scale up)
                const interactables = "a, button, .reading-card, .reading-cta, .nav-logo, .nav-link-block";
                document.querySelectorAll(interactables).forEach(el => {
                    el.addEventListener("mouseenter", () => dot.classList.add("is-hover"));
                    el.addEventListener("mouseleave", () => dot.classList.remove("is-hover"));
                });

                // Click effect
                window.addEventListener("mousedown", () => dot.style.transform += " scale(0.8)");
                window.addEventListener("mouseup", () => dot.style.transform = dot.style.transform.replace(" scale(0.8)", ""));
            }

            // Timeline scroll activation
            const steps = document.querySelectorAll('.how-step');
            const progressBar = document.querySelector('.how-timeline-progress');

            if (steps.length && progressBar) {
                steps.forEach(step => {
                    ScrollTrigger.create({
                        trigger: step,
                        start: 'top 60%',
                        end: 'bottom 40%',
                        onEnter: () => step.classList.add('is-active'),
                        onLeave: () => step.classList.remove('is-active'),
                        onEnterBack: () => step.classList.add('is-active'),
                        onLeaveBack: () => step.classList.remove('is-active'),
                    });
                });

                // Progress line grows as you scroll through the timeline
                const timeline = document.querySelector('.how-timeline');
                if (timeline) {
                    gsap.to(progressBar, {
                        height: '100%',
                        ease: 'none',
                        scrollTrigger: {
                            trigger: timeline,
                            start: 'top 60%',
                            end: 'bottom 60%',
                            scrub: true
                        }
                    });
                }
            }
        });
  </script>
</Layout>
