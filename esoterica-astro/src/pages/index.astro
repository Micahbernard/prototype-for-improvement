---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Esoterica"
  description="Explore a whimsical online magic shop offering mystical products like tarot cards and crystals, designed with enchanting aesthetics for a captivating shopping experience."
>
  <div slot="chrome">
  <a href="#shop" class="skip-to-content">Skip to content</a>

  <!-- ===== LOADING TRANSITION (cosmic core morph) ===== -->
  <div class="transition">
    <div class="loader-ring"></div>
    <div class="loader-ray"></div>
    <div class="loader-core"></div>
  </div>

  <!-- ===== CUSTOM CURSOR (Radiant Orb) ===== -->
  <div class="cursor-dot"></div>

  <!-- ===== STARFIELD CANVAS ===== -->
  <canvas id="starfield"></canvas>

  <!-- ===== FLOATING ORBS ===== -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  </div>

    <!-- ===== HERO (SideStage card entrance pattern) ===== -->
    <div id="top" class="hero-holder">
      <div class="hero-scroll">
        <section class="hero-section">
          <div class="hero-layout">
            <div class="hero-webgl-wrap">
              <canvas id="heroShaderCanvas"></canvas>
            </div>
            <div class="hero-sun" aria-hidden="true"></div>
            <!-- Blinking stars between the spirals (filled by initHeroStars on DOMContentLoaded) -->
            <div class="hero-stars" aria-hidden="true"></div>
            <div class="hero-content">
              <div class="hero-sigil">
                <img src="/logo.png" alt="Esoterica Eye Crystal Ball Logo" width="140" height="140" loading="eager"
                  fetchpriority="high" />
              </div>
              <h1 class="hero-title">
                Where the Veil Between Worlds Grows Thin
              </h1>
              <p class="hero-subtitle">
                Curated crystals, hand-illustrated tarot, and alchemical blends — each artifact chosen to awaken what
                already stirs within you.
              </p>
              <a href="#" data-scroll="shop" class="hero-cta">Enter the Shop</a>
            </div>
            <div class="hero-lower">
              <div class="hero-links-wrap">
                <button type="button" class="nav-link-block" data-scroll="shop">
                  <div class="bracket-left">(</div>
                  <div class="nav-middle-text">
                    <div class="text-nav">shop</div>
                    <div class="text-nav is-duplicate">shop</div>
                  </div>
                  <div class="bracket-right">)</div>
                </button>
                <button type="button" class="nav-link-block" data-scroll="story">
                  <div class="bracket-left">(</div>
                  <div class="nav-middle-text">
                    <div class="text-nav">our story</div>
                    <div class="text-nav is-duplicate">our story</div>
                  </div>
                  <div class="bracket-right">)</div>
                </button>
                <button type="button" class="nav-link-block" data-scroll="offerings">
                  <div class="bracket-left">(</div>
                  <div class="nav-middle-text">
                    <div class="text-nav">offerings</div>
                    <div class="text-nav is-duplicate">offerings</div>
                  </div>
                  <div class="bracket-right">)</div>
                </button>
                <button type="button" class="nav-link-block" data-scroll="commune">
                  <div class="bracket-left">(</div>
                  <div class="nav-middle-text">
                    <div class="text-nav">commune</div>
                    <div class="text-nav is-duplicate">commune</div>
                  </div>
                  <div class="bracket-right">)</div>
                </button>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <!-- ===== PRODUCTS SECTION ===== -->
    <section class="section" id="shop">
      <div class="section-inner">
        <div class="section-divider"></div>
        <p class="section-label">Curated Collection</p>
        <h2 class="section-heading">Sacred Instruments</h2>
        <p class="section-description">
          Tarot and oracle decks, crystals, and simple ritual supplies. Browse in the shop or order online.
        </p>
        <div class="products-grid">
          <div class="product-card">
            <div class="product-card-image">
              <img class="es-media-cover" src="https://images.unsplash.com/photo-1600430188203-bbb0c2e6775e?w=600&h=400&fit=crop&crop=center"
                alt="Tarot Cards" width="600" height="400" loading="lazy" />
            </div>
            <div class="product-card-body">
              <p class="product-card-category">Divination</p>
              <h3 class="product-card-title">Tarot and Oracle Decks</h3>
              <p class="product-card-desc">Cards for tarot and oracle readings. We keep beginner-friendly decks next to
                deeper sets so you can grow into what fits.</p>
              <p class="product-card-tagline">Ask us for a recommendation</p>
            </div>
          </div>
          <div class="product-card">
            <div class="product-card-image">
              <img class="es-media-cover" src="/crystals-pendulums.png"
                alt="Hand holding five crystal pendulums on silver chains" width="800" height="1200" loading="lazy" />
            </div>
            <div class="product-card-body">
              <p class="product-card-category">Crystals</p>
              <h3 class="product-card-title">Crystals</h3>
              <p class="product-card-desc">Stones, pendulums, and small pieces for your desk, pocket, or altar. Stock
                changes as we get new lots in.</p>
              <p class="product-card-tagline">Singles and sets</p>
            </div>
          </div>
          <div class="product-card">
            <div class="product-card-image">
              <img class="es-media-cover" src="https://images.unsplash.com/photo-1596438459194-f275f413d6ff?w=600&h=400&fit=crop&crop=center"
