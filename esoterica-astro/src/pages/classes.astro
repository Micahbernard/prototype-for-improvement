---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
/* ===== HERO (outer shell; inner .sub-hero-cosmos in styles.css) ===== */
        .page-hero {
            padding: 5.5rem 1.25rem 2.5rem;
            position: relative;
        }

        .hero-sigil {
            margin-bottom: 1.5rem;
        }

        .hero-sigil img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            object-position: center 58%;
            border-radius: 50%;
            filter: drop-shadow(0 0 16px rgba(212, 168, 83, 0.3)) drop-shadow(0 0 40px rgba(90, 50, 140, 0.15));
        }

        .hero-breadcrumb {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--es-text-dim);
            margin-bottom: 1.5rem;
        }

        .hero-breadcrumb a {
            color: var(--es-text-whisper);
            transition: color 0.3s;
        }

        .hero-breadcrumb a:hover {
            color: var(--es-gold);
        }

        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 500;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            max-width: 700px;
        }

        .hero-subtitle {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.05rem, 1.8vw, 1.3rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            max-width: var(--es-max-prose);
            margin: 0 auto;
        }

        /* ===== SECTION SHARED ===== */
        .section {
            padding: 6rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        .section-divider {
            width: 60px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--es-gold), transparent);
            margin: 0 auto 2rem;
        }

        .section-label {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 1rem;
        }

        .section-heading {
            font-family: 'Cinzel', serif;
            font-size: clamp(1.8rem, 3.5vw, 2.8rem);
            font-weight: 500;
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .section-description {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            text-align: center;
            max-width: var(--es-max-prose);
            margin: 0 auto 3rem;
        }

        /* ===== CLASS CARDS GRID ===== */
        .classes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .class-card {
            background: var(--es-bg-card-soft);
            border: 1px solid var(--es-border-card);
            border-radius: var(--es-radius-card-sm);
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
            cursor: pointer;
        }

        .class-card:hover {
            transform: translateY(-6px);
            border-color: var(--es-border-card-hover);
            box-shadow: var(--es-shadow-card-hover);
        }

        .class-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 20%, rgba(100, 60, 180, 0.08) 0%, transparent 60%);
            pointer-events: none;
        }

        .class-icon {
            font-size: 2.5rem;
            margin-bottom: 1.2rem;
            display: block;
            color: var(--es-gold);
        }

        .class-icon svg {
            display: block;
            margin: 0 auto;
        }

        .class-badge {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            margin-bottom: 1rem;
        }

        .class-name {
            font-family: 'Cinzel', serif;
            font-size: 1.3rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .class-type {
            font-family: 'Inter', sans-serif;
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-gold);
            margin-bottom: 1rem;
        }

        .class-desc {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: var(--es-text-subtle);
            margin-bottom: 1.5rem;
        }

        .class-details {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            color: var(--es-text-faint);
            margin-bottom: 1.5rem;
            line-height: 1.8;
        }

        .class-price {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--es-gold);
            margin-bottom: 1.5rem;
        }

        .class-cta {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
        }

        .class-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(212, 168, 83, 0.25);
        }

        /* ===== FORMAT SECTION ===== */
        .format-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2.5rem;
            text-align: center;
        }

        .format-item {
            position: relative;
        }

        .format-icon {
            font-size: 2rem;
            color: rgba(212, 168, 83, 0.6);
            margin-bottom: 1rem;
        }

        .format-title {
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            font-weight: 500;
            margin-bottom: 0.6rem;
        }

        .format-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.95rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: var(--es-text-faint);
        }

        /* ===== QUOTE ===== */
        .quote-section {
            text-align: center;
            padding: 5rem 2rem;
        }

        .quote-mark {
            font-family: 'Cinzel', serif;
            font-size: 5rem;
            line-height: 1;
            color: rgba(212, 168, 83, 0.15);
        }

        .quote-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.2rem, 2.5vw, 1.6rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-subtle);
            max-width: 600px;
            margin: 0 auto 1rem;
        }

        .quote-author {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: rgba(var(--es-text-rgb), 0.25);
        }

/* ===== MOBILE ===== */
        @media (max-width: 768px) {
            .nav {
                padding: 1rem 1.5rem;
            }

            .nav-links-wrap {
                display: none;
            }

            .classes-grid {
                grid-template-columns: 1fr;
            }

            .format-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        /* ===== FOCUS STATES (a11y) ===== */
        .nav-link-block:focus-visible,
        .class-cta:focus-visible {
            outline: 2px solid var(--es-gold);
            outline-offset: 3px;
            border-radius: 4px;
        }
</style>

