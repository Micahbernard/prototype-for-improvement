  <script is:inline slot="scripts">
/* ===== STARFIELD ===== */
        (function () {
            const canvas = document.getElementById('starfield');
            const ctx = canvas.getContext('2d');
            let stars = [];
            const STAR_COUNT = 120;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }

            function init() {
                stars = Array.from({ length: STAR_COUNT }, () => ({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: Math.random() * 1.2 + 0.3,
                    alpha: Math.random() * 0.6 + 0.1,
                    speed: Math.random() * 0.008 + 0.004,
                    phase: Math.random() * Math.PI * 2,
                }));
            }

            function draw(t) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                stars.forEach(s => {
                    const a = s.alpha * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(232,224,212,${a})`;
                    ctx.fill();
                });
                requestAnimationFrame(draw);
            }

            resize();
            init();
            window.addEventListener('resize', () => { resize(); init(); });
            requestAnimationFrame(draw);
        })();

        /* ===== CUSTOM CURSOR ===== */
        (function () {
            const dot = document.querySelector('.cursor-dot');
            if (!dot) return;
            document.addEventListener('mousemove', e => {
                dot.style.left = e.clientX + 'px';
                dot.style.top = e.clientY + 'px';
            });
            const interactables = 'a, button, .class-card, .class-cta, .nav-link-block';
            document.querySelectorAll(interactables).forEach(el => {
                el.addEventListener('mouseenter', () => dot.classList.add('is-hover'));
                el.addEventListener('mouseleave', () => dot.classList.remove('is-hover'));
            });
        })();

        /* ===== GSAP ANIMATIONS ===== */
        (function () {
            if (typeof gsap === 'undefined') return;

            gsap.registerPlugin(ScrollTrigger);

            gsap.from('.page-hero .hero-sigil', { opacity: 0, y: -20, duration: 1, ease: 'power3.out', delay: 0.3 });
            gsap.from('.page-hero .hero-breadcrumb', { opacity: 0, y: 10, duration: 0.8, ease: 'power3.out', delay: 0.5 });
            gsap.from('.page-hero .hero-title', { opacity: 0, y: 20, duration: 1, ease: 'power3.out', delay: 0.7 });
            gsap.from('.page-hero .hero-subtitle', { opacity: 0, y: 15, duration: 0.8, ease: 'power3.out', delay: 0.9 });

            document.querySelectorAll('.class-card').forEach((card, i) => {
                gsap.from(card, {
                    scrollTrigger: { trigger: card, start: 'top 85%' },
                    opacity: 0, y: 30, duration: 0.7, ease: 'power3.out', delay: i * 0.08
                });
            });

            document.querySelectorAll('.format-item').forEach((item, i) => {
                gsap.from(item, {
                    scrollTrigger: { trigger: item, start: 'top 88%' },
                    opacity: 0, y: 20, duration: 0.6, ease: 'power2.out', delay: i * 0.1
                });
            });
        })();
  </script>
</Layout>
