  <script is:inline slot="scripts">
/* ===== STARFIELD ===== */
        (function () {
            const canvas = document.getElementById('starfield');
            const ctx = canvas.getContext('2d');
            let stars = [];
            const STAR_COUNT = 120;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }

            function init() {
                stars = Array.from({ length: STAR_COUNT }, () => ({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: Math.random() * 1.2 + 0.3,
                    alpha: Math.random() * 0.6 + 0.1,
                    speed: Math.random() * 0.008 + 0.004,
                    phase: Math.random() * Math.PI * 2,
                }));
            }

            function draw(t) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                stars.forEach(s => {
                    const a = s.alpha * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(232,224,212,${a})`;
                    ctx.fill();
                });
                requestAnimationFrame(draw);
            }

            resize();
            init();
            window.addEventListener('resize', () => { resize(); init(); });
            requestAnimationFrame(draw);
        })();

        /* ===== CUSTOM CURSOR ===== */
        (function () {
            const dot = document.querySelector('.cursor-rune');
            if (!dot) return;
            document.addEventListener('mousemove', e => {
                dot.style.left = e.clientX + 'px';
                dot.style.top = e.clientY + 'px';
            });
            const interactables = 'a, button, .class-card, .class-cta, .nav-link-block';
            document.querySelectorAll(interactables).forEach(el => {
                el.addEventListener('mouseenter', () => dot.classList.add('is-hover'));
                el.addEventListener('mouseleave', () => dot.classList.remove('is-hover'));
            });
            window.addEventListener('mousedown', () => dot.classList.add('is-click'));
            window.addEventListener('mouseup', () => dot.classList.remove('is-click'));
        })();

        /* ===== GSAP ANIMATIONS ===== */
        (function () {
            if (typeof gsap === 'undefined') return;

            gsap.registerPlugin(ScrollTrigger);

            if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                gsap.from('.es-cl-circle__outer-ring, .es-cl-circle__mid-ring, .es-cl-circle__inner-ring', {
                    opacity: 0,
                    scale: 0.9,
                    transformOrigin: '50% 50%',
                    duration: 1.2,
                    ease: 'power2.out',
                    stagger: 0.12,
                    delay: 0.2,
                });
                gsap.from('.es-cl-circle__node', {
                    opacity: 0,
                    scale: 0,
                    transformOrigin: '50% 50%',
                    duration: 0.5,
                    ease: 'back.out(2)',
                    stagger: 0.1,
                    delay: 0.9,
                });
                gsap.from('.es-cl-circle__text', { opacity: 0, duration: 1.4, ease: 'power2.out', delay: 0.6 });
                gsap.from('.es-cl-crumb', { opacity: 0, y: 10, duration: 0.7, ease: 'power3.out', delay: 1.0 });
                gsap.from('.es-cl-rule', {
                    opacity: 0,
                    scaleX: 0,
                    transformOrigin: 'center center',
                    duration: 0.6,
                    ease: 'power2.out',
                    delay: 1.1,
                });
                gsap.from('.es-cl-title', { opacity: 0, y: 20, duration: 1.0, ease: 'power3.out', delay: 1.2 });
                gsap.from('.es-cl-lede', { opacity: 0, y: 15, duration: 0.8, ease: 'power3.out', delay: 1.35 });
            }

            (function initClassesGridReveal() {
                if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
                document.querySelectorAll('.classes-grid').forEach(grid => {
                    const cards = grid.querySelectorAll('.class-card');
                    if (!cards.length) return;
                    gsap.from(cards, {
                        y: 50,
                        opacity: 0,
                        duration: 0.9,
                        stagger: 0.12,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: grid,
                            start: "top 78%",
                            toggleActions: "play none none none"
                        }
                    });
                });
            })();

            document.querySelectorAll('.class-card').forEach(card => {
                const cta = card.querySelector('.class-cta');
                card.addEventListener('mouseenter', () => {
                    gsap.to(card, { y: -6, scale: 1.02, duration: 0.35, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.22em', duration: 0.3, ease: 'power2.out' });
                });
                card.addEventListener('mouseleave', () => {
                    gsap.to(card, { y: 0, scale: 1, duration: 0.5, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.15em', duration: 0.3, ease: 'power2.out' });
                });
            });

            document.querySelectorAll('.format-item').forEach((item, i) => {
                gsap.from(item, {
                    scrollTrigger: { trigger: item, start: 'top 88%' },
                    opacity: 0, y: 20, duration: 0.6, ease: 'power2.out', delay: i * 0.1
                });
            });
        })();
  </script>
</Layout>
