---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Classes & Workshops — Esoterica"
  description="Immersive esoteric classes and workshops. Learn crystal healing, tarot, sacred geometry, and alchemical arts with Esoterica."
  bodyClass="pg-classes"
>

<!-- ===== HERO ===== -->
        <section class="es-cl-hero">
            <div class="es-cl-circle" aria-hidden="true">
                <svg viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <path id="es-cl-arc" d="M 300,300 m -260,0 a 260,260 0 1,1 520,0 a 260,260 0 1,1 -520,0"></path>
                    </defs>
                    <g class="es-cl-circle__rotating">
                        <circle class="es-cl-circle__outer-ring" cx="300" cy="300" r="260"></circle>
                        <text class="es-cl-circle__text">
                            <textPath href="#es-cl-arc" startOffset="0%">∴ KNOWLEDGE IS THE MOST SACRED OFFERING ∴ THE CIRCLE HOLDS WHAT THE MIND FORGETS ∴</textPath>
                        </text>
                        <circle class="es-cl-circle__node" cx="300" cy="40" r="4"></circle>
                        <circle class="es-cl-circle__node" cx="560" cy="300" r="4"></circle>
                        <circle class="es-cl-circle__node" cx="300" cy="560" r="4"></circle>
                        <circle class="es-cl-circle__node" cx="40" cy="300" r="4"></circle>
                    </g>
                    <circle class="es-cl-circle__mid-ring" cx="300" cy="300" r="210"></circle>
                    <circle class="es-cl-circle__inner-ring" cx="300" cy="300" r="170"></circle>
                </svg>
            </div>
            <div class="es-cl-hero__inner">
                <nav class="es-cl-crumb" aria-label="Breadcrumb">
                    <ol>
                        <li><a href="/">Home</a></li>
                        <li><span aria-current="page">Classes &amp; Workshops</span></li>
                    </ol>
                </nav>
                <div class="es-cl-rule" aria-hidden="true"></div>
                <h1 class="es-cl-title">Knowledge Is the Most Sacred Offering</h1>
                <p class="es-cl-lede">
                    Step into the circle. These immersive workshops are gateways to living practice — where ancient wisdom becomes embodied knowing.
                </p>
            </div>
        </section>

        <!-- ===== CLASSES GRID ===== -->
        <section class="section" id="classes">
            <div class="es-ornament" aria-hidden="true"></div>
            <p class="section-label">Choose Your Path</p>
            <h2 class="section-heading">Sacred Workshops</h2>
            <p class="section-description">
                Each class is a ritual in itself — a container of transformation guided by those who have walked the
                path
                before you.
            </p>

            <div class="classes-grid">

                <div class="class-card">
                    <div class="class-card-body">
                        <span class="class-icon" aria-hidden="true">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" stroke-linejoin="round">
                                <polygon
                                    points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                            </svg>
                        </span>
                        <span class="class-badge">Beginner Friendly</span>
                        <h3 class="class-name">Tarot Foundations</h3>
                        <p class="class-type">4-Week Series</p>
                        <p class="class-desc">Learn to read the cards as a living language. From Major Arcana archetypes to
                            intuitive spreads — this course transforms you from curious to confident.</p>
                        <div class="class-card-reveal">
                            <div class="class-details">
                                4 Sessions · 90 min each<br>
                                Study deck provided · Up to 10 students
                            </div>
                            <p class="class-price">$180</p>
                            <a class="class-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20clase%20Tarot%20Foundations." target="_blank" rel="noopener noreferrer">Enroll Now</a>
                        </div>
                    </div>
                </div>

                <div class="class-card">
                    <div class="class-card-body">
                        <span class="class-icon" aria-hidden="true">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="4" />
                                <path
                                    d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
                            </svg>
                        </span>
                        <span class="class-badge">Intermediate</span>
                        <h3 class="class-name">Crystal Healing Arts</h3>
                        <p class="class-type">Workshop · 1 Day</p>
                        <p class="class-desc">Understand the energetic language of stones. Map chakras to crystals, build
                            grids for intention, and attune to the mineral kingdom through hands-on practice.</p>
                        <div class="class-card-reveal">
                            <div class="class-details">
                                6 Hours · Saturday Immersive<br>
                                Crystal kit included · Up to 12 students
                            </div>
                            <p class="class-price">$145</p>
                            <a class="class-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20clase%20Crystal%20Healing%20Arts." target="_blank" rel="noopener noreferrer">Enroll Now</a>
                        </div>
                    </div>
                </div>

                <div class="class-card">
                    <div class="class-card-body">
                        <span class="class-icon" aria-hidden="true">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
                            </svg>
                        </span>
                        <span class="class-badge">All Levels</span>
                        <h3 class="class-name">Lunar Ritual Craft</h3>
                        <p class="class-type">Monthly Ceremony</p>
                        <p class="class-desc">Work with the Moon's cycle as your spiritual calendar. Each month we gather
                            under the new or full moon to set intentions, release, and commune with the cosmos.</p>
                        <div class="class-card-reveal">
                            <div class="class-details">
                                2.5 Hours · Monthly<br>
                                Ritual supplies provided · Up to 15 students
                            </div>
                            <p class="class-price">$75</p>
                            <a class="class-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20clase%20Lunar%20Ritual%20Craft." target="_blank" rel="noopener noreferrer">Join Circle</a>
                        </div>
                    </div>
                </div>

                <div class="class-card">
                    <div class="class-card-body">
                        <span class="class-icon" aria-hidden="true">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 22V8M5 12H2a10 10 0 0 0 20 0h-3" />
                                <path d="M8 6h8M7 3h10" />
                            </svg>
                        </span>
                        <span class="class-badge">Advanced</span>
                        <h3 class="class-name">Alchemical Herbalism</h3>
                        <p class="class-type">6-Week Series</p>
                        <p class="class-desc">Blend the physical and the mystical. Learn to craft ritual tinctures, smudge
                            bundles, and dream teas using plant spirits and alchemical principles.</p>
                        <div class="class-card-reveal">
                            <div class="class-details">
                                6 Sessions · 2 Hours each<br>
                                Herb kit &amp; recipe book included
                            </div>
                            <p class="class-price">$265</p>
                            <a class="class-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20clase%20Alchemical%20Herbalism." target="_blank" rel="noopener noreferrer">Enroll Now</a>
                        </div>
                    </div>
                </div>

                <div class="class-card">
                    <div class="class-card-body">
                        <span class="class-icon" aria-hidden="true">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="3 3 21 3 21 21 3 21 3 3" />
                                <path d="M9 3v18M15 3v18M3 9h18M3 15h18" />
                            </svg>
                        </span>
                        <span class="class-badge">Intermediate</span>
                        <h3 class="class-name">Sacred Geometry</h3>
                        <p class="class-type">Workshop · 1 Day</p>
                        <p class="class-desc">Discover the hidden patterns woven into the fabric of creation. Draw, meditate
                            with, and activate the Flower of Life, Metatron's Cube, and the Sri Yantra.</p>
                        <div class="class-card-reveal">
                            <div class="class-details">
                                5 Hours · Sunday Immersive<br>
                                Drawing kit &amp; workbook provided
                            </div>
                            <p class="class-price">$120</p>
                            <a class="class-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20clase%20Sacred%20Geometry." target="_blank" rel="noopener noreferrer">Enroll Now</a>
                        </div>
                    </div>
                </div>

                <div class="class-card">
                    <div class="class-card-body">
                        <span class="class-icon" aria-hidden="true">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
                                <path d="M9 18h6M10 22h4" />
                            </svg>
                        </span>
                        <span class="class-badge">All Levels</span>
                        <h3 class="class-name">Intuition Awakening</h3>
                        <p class="class-type">2-Week Intensive</p>
                        <p class="class-desc">A dedicated practice to unlock and trust your inner knowing. Includes psychic
                            development exercises, dreamwork journaling, and guided meditations.</p>
                        <div class="class-card-reveal">
                            <div class="class-details">
                                4 Sessions · 90 min each<br>
                                Dream journal included · Live &amp; recorded
                            </div>
                            <p class="class-price">$155</p>
                            <a class="class-cta" href="https://wa.me/51919623179?text=Hola%20Esoterica%2C%20me%20interesa%20la%20clase%20Intuition%20Awakening." target="_blank" rel="noopener noreferrer">Enroll Now</a>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- ===== WHAT TO EXPECT ===== -->
        <section class="section" id="format">
            <div class="es-ornament" aria-hidden="true"></div>
            <p class="section-label">The Experience</p>
            <h2 class="section-heading">What to Expect</h2>
            <p class="section-description">
                Every class is designed as sacred space — intimate, embodied, and transformative.
            </p>

            <div class="format-grid">
                <div class="format-item">
                    <div class="format-icon">🕯</div>
                    <h3 class="format-title">Ritual Opening</h3>
                    <p class="format-text">Each session begins with an intentional ceremony — grounding, smudging, and
                        invocation of the directions.</p>
                </div>
                <div class="format-item">
                    <div class="format-icon">📿</div>
                    <h3 class="format-title">Embodied Learning</h3>
                    <p class="format-text">We move beyond theory into direct experience. Every concept is felt,
                        practiced, and integrated in real time.</p>
                </div>
                <div class="format-item">
                    <div class="format-icon">🌙</div>
                    <h3 class="format-title">Small Circles</h3>
                    <p class="format-text">Capped enrollment ensures every student receives personal attention and the
                        energy of true community.</p>
                </div>
                <div class="format-item">
                    <div class="format-icon">✨</div>
                    <h3 class="format-title">Take It Home</h3>
                    <p class="format-text">Materials, ritual kits, and recordings are included so your practice
                        continues long after the circle closes.</p>
                </div>
            </div>
        </section>

        <!-- ===== QUOTE ===== -->
        <div class="quote-section">
            <div class="es-ornament" aria-hidden="true"></div>
            <div class="quote-mark">"</div>
            <p class="quote-text">To teach is to create a corridor between what is known and what yearns to be
                discovered.</p>
            <p class="quote-author">— The Keeper of Veils</p>
        </div>
  <script is:inline slot="scripts">
        /* ===== GSAP ANIMATIONS ===== */
        (function () {
            if (typeof gsap === 'undefined') return;

            gsap.registerPlugin(ScrollTrigger);

            if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                gsap.from('.es-cl-circle__outer-ring, .es-cl-circle__mid-ring, .es-cl-circle__inner-ring', {
                    opacity: 0,
                    scale: 0.9,
                    transformOrigin: '50% 50%',
                    duration: 1.2,
                    ease: 'power2.out',
                    stagger: 0.12,
                    delay: 0.2,
                });
                gsap.from('.es-cl-circle__node', {
                    opacity: 0,
                    scale: 0,
                    transformOrigin: '50% 50%',
                    duration: 0.5,
                    ease: 'back.out(2)',
                    stagger: 0.1,
                    delay: 0.9,
                });
                gsap.from('.es-cl-circle__text', { opacity: 0, duration: 1.4, ease: 'power2.out', delay: 0.6 });
                gsap.from('.es-cl-crumb', { opacity: 0, y: 10, duration: 0.7, ease: 'power3.out', delay: 1.0 });
                gsap.from('.es-cl-rule', {
                    opacity: 0,
                    scaleX: 0,
                    transformOrigin: 'center center',
                    duration: 0.6,
                    ease: 'power2.out',
                    delay: 1.1,
                });
                gsap.from('.es-cl-title', { opacity: 0, y: 20, duration: 1.0, ease: 'power3.out', delay: 1.2 });
                gsap.from('.es-cl-lede', { opacity: 0, y: 15, duration: 0.8, ease: 'power3.out', delay: 1.35 });
            }

            (function initClassesGridReveal() {
                if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
                document.querySelectorAll('.classes-grid').forEach(grid => {
                    const cards = grid.querySelectorAll('.class-card');
                    if (!cards.length) return;
                    gsap.from(cards, {
                        y: 50,
                        opacity: 0,
                        duration: 0.9,
                        stagger: 0.12,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: grid,
                            start: "top 78%",
                            toggleActions: "play none none none"
                        }
                    });
                });
            })();

            document.querySelectorAll('.class-card').forEach(card => {
                const cta = card.querySelector('.class-cta');
                card.addEventListener('mouseenter', () => {
                    gsap.to(card, { y: -6, scale: 1.02, duration: 0.35, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.22em', duration: 0.3, ease: 'power2.out' });
                });
                card.addEventListener('mouseleave', () => {
                    gsap.to(card, { y: 0, scale: 1, duration: 0.5, ease: 'power2.out' });
                    if (cta) gsap.to(cta, { letterSpacing: '0.15em', duration: 0.3, ease: 'power2.out' });
                });
            });

            document.querySelectorAll('.format-item').forEach((item, i) => {
                gsap.from(item, {
                    scrollTrigger: { trigger: item, start: 'top 88%' },
                    opacity: 0, y: 20, duration: 0.6, ease: 'power2.out', delay: i * 0.1
                });
            });
        })();
  </script>
</Layout>
