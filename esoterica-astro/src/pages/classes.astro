---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
        /* ===== SECTION SHARED ===== */
        /* inner-page override */
        .section {
            padding: 6rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        /* inner-page override */
        .section-divider {
            width: 60px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--es-gold), transparent);
            margin: 0 auto 2rem;
        }

        /* inner-page override */
        .section-label {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 1rem;
        }

        /* inner-page override */
        .section-description {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-muted);
            text-align: center;
            max-width: var(--es-max-prose);
            margin: 0 auto 3rem;
        }

        /* ===== CLASS CARDS GRID ===== */
        .classes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .class-card {
            background: var(--es-bg-card-soft);
            border: 1px solid var(--es-border-card);
            border-radius: var(--es-radius-card-sm);
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
            cursor: pointer;
        }

        .class-card:hover {
            transform: translateY(-6px);
            border-color: var(--es-border-card-hover);
            box-shadow: var(--es-shadow-card-hover);
        }

        .class-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 20%, rgba(100, 60, 180, 0.08) 0%, transparent 60%);
            pointer-events: none;
        }

        .class-icon {
            font-size: 2.5rem;
            margin-bottom: 1.2rem;
            display: block;
            color: var(--es-gold);
        }

        .class-icon svg {
            display: block;
            margin: 0 auto;
        }

        .class-badge {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            margin-bottom: 1rem;
        }

        .class-name {
            font-family: 'Cinzel', serif;
            font-size: 1.3rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .class-type {
            font-family: 'Inter', sans-serif;
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-gold);
            margin-bottom: 1rem;
        }

        .class-desc {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: var(--es-text-subtle);
            margin-bottom: 1.5rem;
            flex: 1;
        }

        .class-details {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            color: var(--es-text-faint);
            margin-bottom: 1.5rem;
            line-height: 1.8;
        }

        .class-price {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--es-gold);
            margin-bottom: 1.5rem;
        }

        .class-cta {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--es-bg-deep);
            background: linear-gradient(135deg, var(--es-gold), var(--es-gold-light));
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: pointer;
        }

        .class-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(212, 168, 83, 0.25);
        }

        .reading-card,
        .class-card {
            position: relative;
            overflow: hidden;
            height: 420px;
            z-index: 0;
        }

        .reading-card-reveal,
        .class-card-reveal {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 2rem 1.75rem 1.75rem;
            background: linear-gradient(
                to top,
                var(--es-bg-card) 0%,
                var(--es-bg-card) 75%,
                transparent 100%
            );
            transform: translateY(100%);
            transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            border-top: 1px solid color-mix(in srgb, var(--es-gold) 18%, transparent);
            backdrop-filter: blur(0px);
        }

        .reading-card:hover .reading-card-reveal,
        .class-card:hover .class-card-reveal {
            transform: translateY(0);
        }

        .reading-card-body,
        .class-card-body {
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        /* ===== FORMAT SECTION ===== */
        .format-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2.5rem;
            text-align: center;
        }

        .format-item {
            position: relative;
        }

        .format-icon {
            font-size: 2rem;
            color: rgba(var(--es-gold-rgb), 0.6);
            margin-bottom: 1rem;
        }

        .format-title {
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            font-weight: 500;
            margin-bottom: 0.6rem;
        }

        .format-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.95rem;
            font-weight: 300;
            font-style: italic;
            line-height: 1.6;
            color: var(--es-text-faint);
        }

        /* ===== QUOTE ===== */
        /* inner-page override */
        .quote-section {
            text-align: center;
            padding: 5rem 2rem;
        }

        /* inner-page override */
        .quote-mark {
            font-family: 'Cinzel', serif;
            font-size: 5rem;
            line-height: 1;
            color: rgba(var(--es-gold-rgb), 0.15);
        }

        /* inner-page override */
        .quote-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.2rem, 2.5vw, 1.6rem);
            font-weight: 300;
            font-style: italic;
            line-height: 1.7;
            color: var(--es-text-subtle);
            max-width: 600px;
            margin: 0 auto 1rem;
        }

        /* inner-page override */
        .quote-author {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--es-text-dim);
        }

/* ===== MOBILE ===== */
        @media (max-width: 768px) {
            /* inner-page override */
            .nav {
                padding: 1rem 1.5rem;
            }

            .classes-grid {
                grid-template-columns: 1fr;
            }

            .format-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

</style>

